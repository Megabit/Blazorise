@typeparam TValue
@inherits Blazorise.DatePicker<TValue>
@if ( Plaintext )
{
    <span @ref="@ElementRef" id="@ElementId" class="@ClassNames" style="@StyleNames" @attributes="@Attributes">
        @CurrentValueAsString
    </span>
}
else
{
    <div class="@ContainerClassNames" style="@StyleNames" @onclick="@OnPickerClickHandler">
        <div class="ant-picker-input">
            <input @ref="@ElementRef" id="@ElementId" type="text" name="@NameAttributeValue" disabled="@IsDisabled" readonly="@ReadOnly" pattern="@Pattern" value="@CurrentValueAsString" @onchange="@OnChangeHandler" placeholder="@Placeholder" min="@Min?.ToString( Utilities.Parsers.InternalDateFormat )" max="@Max?.ToString( Utilities.Parsers.InternalDateFormat )" tabindex="@TabIndex" aria-invalid="@ResolvedAriaInvalid" aria-required="@ResolvedAriaRequired" aria-describedby="@ResolvedAriaDescribedBy" aria-labelledby="@ExplicitAriaLabelledBy" @attributes="@Attributes" />
        </div>
        <span class="ant-picker-suffix" aria-hidden="true">
            <span role="img" aria-label="calendar" class="anticon anticon-calendar">
                <svg viewBox="64 64 896 896" focusable="false" data-icon="calendar" width="1em" height="1em" fill="currentColor" aria-hidden="true">
                    <path d="M880 184H712v-64c0-4.4-3.6-8-8-8h-56c-4.4 0-8 3.6-8 8v64H384v-64c0-4.4-3.6-8-8-8h-56c-4.4 0-8 3.6-8 8v64H144c-17.7 0-32 14.3-32 32v664c0 17.7 14.3 32 32 32h736c17.7 0 32-14.3 32-32V216c0-17.7-14.3-32-32-32zm-40 656H184V360h656v480z"></path>
                </svg>
            </span>
        </span>
    </div>
}
@ChildContent
@Feedback
@code {
    string ContainerClassNames => IsDisabled
        ? $"{ClassNames} ant-picker-disabled"
        : ClassNames;

    Task OnPickerClickHandler( MouseEventArgs eventArgs )
        => IsDisabled || ReadOnly
            ? Task.CompletedTask
            : OnClickHandler( eventArgs );
}