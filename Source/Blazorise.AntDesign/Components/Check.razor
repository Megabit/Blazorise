@typeparam TValue
@inherits Blazorise.Check<TValue>
@using Blazorise.Utilities
<label @ref="@wrapperRef" class="@WrapperClassNames" style="@WrapperStyleNames">
    <span class="@CheckboxClassNames">
        <input @ref="@ElementRef" id="@ElementId" type="checkbox" name="@Name" class="@ClassNames" style="@StyleNames" disabled="@IsDisabled" readonly="@ReadOnly" checked="@IsChecked" tabindex="@TabIndex" aria-invalid="@ResolvedAriaInvalid" aria-required="@ResolvedAriaRequired" aria-describedby="@ResolvedAriaDescribedBy" aria-labelledby="@ExplicitAriaLabelledBy" @onclick:preventDefault="@ReadOnly" @onchange="@OnChangeHandler" @onkeydown="@OnKeyDownHandler" @onkeypress="@OnKeyPressHandler" @onkeyup="@OnKeyUpHandler" @onblur="@OnBlurHandler" @onfocus="@OnFocusHandler" @onfocusin="@OnFocusInHandler" @onfocusout="@OnFocusOutHandler" @attributes="@Attributes" />
        <span class="@InnerClassNames"></span>
    </span>
    <span>
        @ChildContent
        @Feedback
    </span>
</label>
@code {
    private ClassBuilder wrapperClassBuilder;
    private StyleBuilder wrapperStyleBuilder;

    protected override void OnInitialized()
    {
        wrapperClassBuilder = new( BuildWrapperClasses );
        wrapperStyleBuilder = new( BuildWrapperStyles );

        base.OnInitialized();
    }

    protected internal override void DirtyClasses()
    {
        wrapperClassBuilder?.Dirty();

        base.DirtyClasses();
    }

    protected internal override void DirtyStyles()
    {
        wrapperStyleBuilder?.Dirty();

        base.DirtyStyles();
    }

    private void BuildWrapperClasses( ClassBuilder builder )
    {
        builder.Append( "ant-checkbox-wrapper" );
        builder.Append( ClassProvider.CheckInline( Inline ) );
        builder.Append( CheckSizeClass );

        if ( IsChecked )
        {
            builder.Append( "ant-checkbox-wrapper-checked" );
        }

        if ( IsDisabled )
        {
            builder.Append( "ant-checkbox-wrapper-disabled" );
        }

        builder.Append( Classes?.Wrapper );
        AppendWrapperUtilities( builder );
    }

    private void BuildWrapperStyles( StyleBuilder builder )
    {
        AppendWrapperUtilities( builder );
        builder.Append( Styles?.Wrapper );
    }

    string WrapperClassNames => wrapperClassBuilder.Class;

    string WrapperStyleNames => wrapperStyleBuilder.Styles;

    string CheckboxClassNames
    {
        get
        {
            var sb = new System.Text.StringBuilder( "ant-checkbox ant-wave-target" );
            var sizeClass = CheckSizeClass;

            if ( !string.IsNullOrEmpty( sizeClass ) )
            {
                sb.Append( $" {sizeClass}" );
            }

            if ( IsChecked )
            {
                sb.Append( " ant-checkbox-checked" );
            }

            if ( Indeterminate == true )
            {
                sb.Append( " ant-checkbox-indeterminate" );
            }

            if ( IsDisabled )
            {
                sb.Append( " ant-checkbox-disabled" );
            }

            return sb.ToString();
        }
    }

    bool IsChecked => CurrentValue?.ToString() == bool.TrueString;

    string CheckSizeClass => ThemeSize != Blazorise.Size.Default
        ? $"b-ant-checkbox-{ClassProvider.ToSize( ThemeSize )}"
        : null;

    string InnerClassNames
        => "ant-checkbox-inner";
}