@inherits Blazorise.Fields
<CascadingValue Value="@this" IsFixed>
    @if ( Group )
    {
        <Dynamic TagName="@ContainerTagName" @bind-ElementRef="@ElementRef" id="@ElementId" class="@ClassNames" style="@StyleNames" @attributes="@Attributes">
            @if ( Label is not null )
            {
                <FieldsLabel>@Label</FieldsLabel>
            }
            @ChildContent
        </Dynamic>
    }
    else
    {
        @if ( Label is not null )
        {
            <FieldsLabel>@Label</FieldsLabel>
        }
        <Dynamic TagName="@ContainerTagName" @bind-ElementRef="@ElementRef" id="@ElementId" class="@ClassNames" style="@StyleNames" @attributes="@Attributes">
            @ChildContent
        </Dynamic>
    }
    @if ( Help is not null )
    {
        <Help>@Help</Help>
    }
</CascadingValue>