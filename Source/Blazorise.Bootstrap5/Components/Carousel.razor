@inherits Blazorise.Carousel
<CascadingValue Value="@this" IsFixed>
    <CascadingValue Value="@State">
        @ChildContent

        <div @ref="@ElementRef" id="@ElementId" class="@ClassNames" style="@StyleNames" data-ride="carousel" @attributes="@Attributes">
            @if ( ShowIndicators )
            {
                <div class="@IndicatorsClassNames" style="@IndicatorsStyleNames">
                    @for ( int i = 0; i < carouselSlides.Count; ++i )
                    {
                        int index = i;
                        @if ( IndicatorTemplate is not null )
                        {
                            @IndicatorTemplate( CreateIndicatorContext( index ) )
                        }
                        else
                        {
                            <button type="button" @onclick="@carouselSlides[index].Activate" class="@carouselSlides[index].IndicatorClassNames" style="@carouselSlides[index].IndicatorStyleNames" data-bs-target aria-label="@($"Slide {index}")"></button>
                        }
                    }
                </div>
            }

            <div class="@SlidesClassNames" style="@SlidesStyleNames">
                @for ( int i = 0; i < carouselSlides.Count; ++i )
                {
                    int index = i;
                    <div class="@carouselSlides[index].ClassNames" style="@carouselSlides[index].StyleNames" @attributes="@carouselSlides[index].Attributes">
                        @RenderSlideContent( carouselSlides[index] )
                    </div>
                }
            </div>

            @if ( ShowControls )
            {
                @if ( PreviousButtonTemplate is not null )
                {
                    @PreviousButtonTemplate( CreateNavigationContext( CarouselDirection.Previous ) )
                }
                else
                {
                    <a class="carousel-control-prev" @onclick="@SelectPrevious" role="button" data-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">@PreviousButtonString</span>
                    </a>
                }

                @if ( NextButtonTemplate is not null )
                {
                    @NextButtonTemplate( CreateNavigationContext( CarouselDirection.Next ) )
                }
                else
                {
                    <a class="carousel-control-next" @onclick="@SelectNext" role="button" data-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">@NextButtonString</span>
                    </a>
                }
            }
        </div>
    </CascadingValue>
</CascadingValue>