@namespace Blazorise
@inherits BaseComponent
@if ( Visible )
{
    <Div ElementId="@ElementId" Class="@ClassNames" Style="@StyleNames" role="application" aria-label="@AriaLabel" @attributes="@Attributes">
        @if ( ChildContent is not null )
        {
            @ChildContent
        }
        else
        {
            @foreach ( var row in Rows )
            {
                <Div Display="Blazorise.Display.Flex" Gap="Blazorise.Gap.Is1" Margin="Blazorise.Margin.Is1.FromBottom">
                    @foreach ( var key in row )
                    {
                        <Button Color="@KeyColor" Size="@KeySize" Style="@GetKeyStyle( key )" TabIndex="-1" Clicked="@(() => OnKeyClicked( key ))" @onmousedown:preventDefault>
                            @GetKeyDisplayText( key )
                        </Button>
                    }
                </Div>
            }
        }
    </Div>
}