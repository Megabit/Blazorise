@namespace Blazorise
@inherits BaseComponent
<CascadingValue Value="@this" IsFixed>
    <section @ref="@ElementRef" id="@ElementId" class="@ClassNames" style="@StyleNames" @attributes="@Attributes">
        <CascadingValue Value="@RootCollector" IsFixed="false">
            <div style="display:none">
                @ChildContent
            </div>
        </CascadingValue>
        @if ( CurrentState.Root is not null )
        {
            <_DockNodeRenderer Layout="@this" Node="@CurrentState.Root" />
        }
        @if ( DockGuidesVisible )
        {
            <div class="@GetDockCompassClass()" style="@DockCompassStyleNames">
                @foreach ( DockCompassZoneInfo compassZone in DockCompassZones )
                {
                    <div class="@GetDockCompassZoneClass( compassZone )"></div>
                }
            </div>
        }
    </section>
</CascadingValue>