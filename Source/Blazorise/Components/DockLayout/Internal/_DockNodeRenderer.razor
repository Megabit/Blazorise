@namespace Blazorise
@inherits BaseComponent
@if ( Node?.Kind == DockNodeKind.Split )
{
    <div class="@ClassNames" style="@SplitStyle" data-dock-node-id="@Node.Id" data-dock-split>
        <_DockNodeRenderer NodeId="@Node.First?.Id" SplitterDock="@FirstSplitterDock" SplitNodeId="@Node.Id" />
        <_DockNodeRenderer NodeId="@Node.Second?.Id" SplitterDock="@SecondSplitterDock" SplitNodeId="@Node.Id" />
        @if ( CanResize )
        {
            <DockSplitter PaneName="@Node.Id" Dock="@SplitterDock.Value" NodeId="@SplitNodeId" />
        }
    </div>
}
else if ( Node?.Kind == DockNodeKind.Tabs )
{
    <_DockTabsRenderer NodeId="@Node.Id" SplitterDock="@SplitterDock" SplitNodeId="@SplitNodeId" />
}
else if ( Node?.Kind == DockNodeKind.Pane )
{
    <_DockPaneRenderer NodeId="@Node.Id" PaneName="@Node.PaneName" SplitterDock="@SplitterDock" SplitNodeId="@SplitNodeId" />
}
else if ( Node?.Kind == DockNodeKind.Content )
{
    <_DockContentRenderer />
}