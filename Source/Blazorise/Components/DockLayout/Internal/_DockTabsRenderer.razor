@namespace Blazorise
@inherits BaseComponent
@if ( Visible )
{
    <CascadingValue Value="@ActivePane" IsFixed="false">
        <aside @ref="@CapturedElementRef" class="@ClassNames" style="@StyleNames" data-dock-node-id="@Node.Id" data-dock-pane-name="@ActivePaneName" data-dock-pane-caption="@ActivePane.ResolvedCaption">
            @if ( TabsVisible && TabsOnTop )
            {
                <div class="@TabsClassNames">
                    @foreach ( string paneName in Node.Panes )
                    {
                        <_DockTabRenderer @key="@paneName" NodeId="@NodeId" PaneName="@paneName" GroupPosition="@GroupPosition" />
                    }
                </div>
            }

            @ActivePane.ChildContent
            @if ( TabsVisible && !TabsOnTop )
            {
                <div class="@TabsClassNames">
                    @foreach ( string paneName in Node.Panes )
                    {
                        <_DockTabRenderer @key="@paneName" NodeId="@NodeId" PaneName="@paneName" GroupPosition="@GroupPosition" />
                    }
                </div>
            }

            @if ( CanResize )
            {
                <DockSplitter Dock="@SplitterDock.Value" NodeId="@SplitNodeId" />
            }
        </aside>
    </CascadingValue>
}