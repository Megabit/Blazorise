@namespace Blazorise
@inherits BaseComponent

<a @ref="@ElementRef" id="@ElementId" class="@ClassNames" style="@StyleNames" role="menuitem" aria-disabled="@AriaDisabled" @onmousedown:preventDefault @onmousedown="@EventCallback.Empty" @onclick="@ClickHandler" @attributes="@Attributes">
    @Core
</a>

@code {
    private protected RenderFragment Core =>
        @<text>
            @if ( ShowCheckbox )
            {
                @* Keep checkbox/label native defaults suppressed so every click path resolves through DropdownItem.ClickHandler. *@
                <div style="display: inline-block;" @onclick:preventDefault @onclick="@EventCallback.Empty">
                    <Check Cursor="Cursor.Pointer" TValue="bool" Value="@(@checked)" ValueChanged="@CheckedChangedHandler" ValueExpression="@checkedExpression" Disabled="@Disabled">
                        @ChildContent
                    </Check>
                </div>
            }
            else
            {
                @ChildContent
            }
        </text>;
}