@inherits BaseComponent
@typeparam TItem
<Div ElementId="@ElementId" Class="@ClassNames" Style="@StyleNames" Flex="FlexColumn" Border="BorderIs1" role="application">
    <CascadingValue Value="@this" IsFixed>
        @if ( ShowToolbar && ganttToolbar is not null )
        {
            <_GanttToolbar TItem="TItem"
                           SelectedDate="@currentDate"
                           SelectedView="@SelectedView"
                           FirstDayOfWeek="@FirstDayOfWeek"
                           SearchText="@searchText"
                           SearchInputWidth="@GetSearchInputWidth()"
                           ShowAddTaskButton="@ShowToolbarAddTaskButton"
                           ShowTitleColumn="@showTitleColumn"
                           ShowStartColumn="@showStartColumn"
                           ShowEndColumn="@showEndColumn"
                           ShowDurationColumn="@showDurationColumn"
                           ShowCommandColumn="@showCommandColumn"
                           ShowToggleAllCommands="@ShowToggleAllCommands"
                           ShowDayViewButton="@(ganttDayView is not null)"
                           ShowWeekViewButton="@(ganttWeekView is not null)"
                           ShowMonthViewButton="@(ganttMonthView is not null)"
                           ShowYearViewButton="@(ganttYearView is not null)"
                           PreviousClicked="@NavigatePreviousPeriod"
                           NextClicked="@NavigateNextPeriod"
                           TodayClicked="@NavigateToday"
                           DayViewClicked="@ShowDayView"
                           WeekViewClicked="@ShowWeekView"
                           MonthViewClicked="@ShowMonthView"
                           YearViewClicked="@ShowYearView"
                           AddTaskClicked="@New"
                           ExpandAllClicked="@ExpandAll"
                           CollapseAllClicked="@CollapseAll"
                           SearchTextChanged="@SetSearchText"
                           ShowTitleColumnChanged="@SetShowTitleColumn"
                           ShowStartColumnChanged="@SetShowStartColumn"
                           ShowEndColumnChanged="@SetShowEndColumn"
                           ShowDurationColumnChanged="@SetShowDurationColumn"
                           ShowCommandColumnChanged="@SetShowCommandColumn" />
        }

        @{
            var visibleRows = GetVisibleRows();
            if ( KeyboardNavigation )
            {
                EnsureFocusedRow( visibleRows );
            }
            var viewRange = GetCurrentViewRange();
            var timeSlots = GetTimeSlots( viewRange.Start, viewRange.End );
            var rowTemplate = RowTemplateForCurrentView;
            var itemTemplate = ItemTemplateForCurrentView;
            var rowHeight = GetRowHeight();
            var headerRowHeight = GetHeaderRowHeight();
            var cellWidth = GetTimelineCellWidth();
            var treeToggleWidth = GetTreeToggleWidth();
            var showActionColumn = CanShowActionColumn( visibleRows );
            var showHeaderNewButton = ShowHeaderNewButton;
        }

        <_GanttBody Style="@GetBodyStyle()">
            <_GanttTreePane Style="@GetTreePaneStyle( showActionColumn )">
                <_GanttTreeHeader Height="Blazorise.Height.Px( headerRowHeight )" Border="BorderIs1OnBottom" Position="PositionStickyTopIs0" Background="Background.Body">
                    @if ( showTitleColumn )
                    {
                        <Div Style="@GetTitleColumnStyle()"
                             Padding="PaddingIs2OnX"
                             TextWeight="TextWeight.SemiBold"
                             Cursor="@(Sortable ? Cursor.Pointer : Cursor.Default)"
                             @onclick="@(() => SortByColumn( GanttSortColumn.Title ))">
                            <Div Flex="FlexAlignItemsCenterNoWrap" Gap="GapIs1">
                                <Span>@TaskColumnHeaderText</Span>
                                @if ( ShowSortIcon( GanttSortColumn.Title ) )
                                {
                                    <Icon Name="@GetSortIconName( GanttSortColumn.Title )" />
                                }
                            </Div>
                        </Div>
                    }
                    @if ( showStartColumn )
                    {
                        <Div Style="@GetDateColumnStyle()"
                             Padding="PaddingIs2OnX"
                             TextWeight="TextWeight.SemiBold"
                             Cursor="@(Sortable ? Cursor.Pointer : Cursor.Default)"
                             @onclick="@(() => SortByColumn( GanttSortColumn.Start ))">
                            <Div Flex="FlexAlignItemsCenterNoWrap" Gap="GapIs1">
                                <Span>@StartColumnHeaderText</Span>
                                @if ( ShowSortIcon( GanttSortColumn.Start ) )
                                {
                                    <Icon Name="@GetSortIconName( GanttSortColumn.Start )" />
                                }
                            </Div>
                        </Div>
                    }
                    @if ( showEndColumn )
                    {
                        <Div Style="@GetDateColumnStyle()"
                             Padding="PaddingIs2OnX"
                             TextWeight="TextWeight.SemiBold"
                             Cursor="@(Sortable ? Cursor.Pointer : Cursor.Default)"
                             @onclick="@(() => SortByColumn( GanttSortColumn.End ))">
                            <Div Flex="FlexAlignItemsCenterNoWrap" Gap="GapIs1">
                                <Span>@EndColumnHeaderText</Span>
                                @if ( ShowSortIcon( GanttSortColumn.End ) )
                                {
                                    <Icon Name="@GetSortIconName( GanttSortColumn.End )" />
                                }
                            </Div>
                        </Div>
                    }
                    @if ( showDurationColumn )
                    {
                        <Div Style="@GetDateColumnStyle()"
                             Padding="PaddingIs2OnX"
                             TextWeight="TextWeight.SemiBold"
                             Cursor="@(Sortable ? Cursor.Pointer : Cursor.Default)"
                             @onclick="@(() => SortByColumn( GanttSortColumn.Duration ))">
                            <Div Flex="FlexAlignItemsCenterNoWrap" Gap="GapIs1">
                                <Span>@DurationColumnHeaderText</Span>
                                @if ( ShowSortIcon( GanttSortColumn.Duration ) )
                                {
                                    <Icon Name="@GetSortIconName( GanttSortColumn.Duration )" />
                                }
                            </Div>
                        </Div>
                    }
                    @if ( showActionColumn )
                    {
                        <Div Style="@GetActionColumnStyle()">
                            @if ( showHeaderNewButton )
                            {
                                <Button Size="Size.ExtraSmall" Clicked="@New" Border="BorderIs0" Background="Background.Transparent" TextColor="TextColor.Muted" aria-label="@AddTaskText">
                                    <Icon Name="IconName.Add" />
                                </Button>
                            }
                        </Div>
                    }
                </_GanttTreeHeader>

                <_GanttTreeRows @ref="ganttTreeRowsRef" Style="@GetTreeRowsStyle()" TabIndex="@(KeyboardNavigation ? 0 : -1)" KeyDown="@OnTreeRowsKeyDown">
                    @if ( visibleRows.Count == 0 )
                    {
                        <Div Padding="PaddingIs3" TextColor="TextColor.Muted">@NoTasksToDisplayText</Div>
                    }
                    else
                    {
                        @foreach ( var node in visibleRows )
                        {
                            <_GanttTreeRow @key="@node.Key"
                                           Style="@GetTreeRowStyle( rowHeight )"
                                           Background="@GetFocusedRowBackground( node.Key )"
                                           Selected="@IsFocusedRow( node.Key )"
                                           Clicked="@(() => FocusRow( node.Key ))"
                                           DoubleClicked="@(() => OnTreeRowDoubleClicked( node.Item, node.Key ))">
                                @if ( showTitleColumn )
                                {
                                    <Div Style="@GetTitleColumnStyle()" Padding="PaddingIs2OnX">
                                        <Div Flex="FlexAlignItemsCenter" Style="@GetTreeTitleContentStyle( node.Level )">
                                            @if ( node.HasChildren )
                                            {
                                                <Button Size="Size.ExtraSmall" Clicked="@(() => ToggleNode( node ))" Margin="MarginIs1FromEnd" aria-label="Toggle">
                                                    <Icon Name="@(IsExpanded( node ) ? IconName.ChevronDown : IconName.ChevronRight)" />
                                                </Button>
                                            }
                                            else
                                            {
                                                <Span Display="DisplayInlineBlock" Width="Blazorise.Width.Px( treeToggleWidth )"></Span>
                                            }

                                            @if ( rowTemplate is not null )
                                            {
                                                @rowTemplate( new GanttRowContext<TItem>( node.Item, node.Level, node.HasChildren, IsExpanded( node ) ) )
                                            }
                                            else
                                            {
                                                <Span TextOverflow="TextOverflow.Truncate" Width="WidthIs100">@GetItemTitle( node.Item )</Span>
                                            }
                                        </Div>
                                    </Div>
                                }
                                @if ( showStartColumn )
                                {
                                    <Div Style="@GetDateColumnStyle()" Padding="PaddingIs2OnX">
                                        <Span TextSize="TextSizeSmall">@FormatDate( GetItemStart( node.Item ) )</Span>
                                    </Div>
                                }
                                @if ( showEndColumn )
                                {
                                    <Div Style="@GetDateColumnStyle()" Padding="PaddingIs2OnX">
                                        <Span TextSize="TextSizeSmall">@FormatDate( GetItemEnd( node.Item ) )</Span>
                                    </Div>
                                }
                                @if ( showDurationColumn )
                                {
                                    <Div Style="@GetDateColumnStyle()" Padding="PaddingIs2OnX">
                                        <Span TextSize="TextSizeSmall">@FormatDuration( GetItemDuration( node.Item ) )</Span>
                                    </Div>
                                }
                                @if ( showActionColumn )
                                {
                                    <Div Style="@GetActionColumnStyle()">
                                        @if ( CanShowAddChildButton( node.Item ) )
                                        {
                                            <Button Size="Size.ExtraSmall" Clicked="@(() => AddChild( node.Item ))" Border="BorderIs0" Background="Background.Transparent" aria-label="@AddChildText">
                                                <Icon Name="IconName.Add" />
                                            </Button>
                                        }
                                    </Div>
                                }
                            </_GanttTreeRow>
                        }
                    }
                </_GanttTreeRows>
            </_GanttTreePane>

            <_GanttTimelinePane Style="@GetTimelinePaneStyle()">
                <_GanttTimelineViewport Style="@GetTimelineViewportStyle()">
                    <_GanttTimelineInner Style="@GetTimelineInnerStyle( timeSlots.Count, cellWidth )">
                        <_GanttTimeHeader Height="Blazorise.Height.Px( headerRowHeight )" Border="BorderIs1OnBottom" Position="PositionStickyTopIs0" Background="Background.Body">
                            @foreach ( var slot in timeSlots )
                            {
                                <Div @key="@slot.Key" Style="@GetTimelineHeaderCellStyle( cellWidth )" Padding="PaddingIs1OnX">
                                    <Span TextSize="TextSizeSmall" TextWeight="TextWeight.SemiBold">@slot.Label</Span>
                                </Div>
                            }
                        </_GanttTimeHeader>

                        @foreach ( var node in visibleRows )
                        {
                            <_GanttTimeRow @key="@($"timeline-{node.Key}")" Style="@GetTimelineRowStyle( rowHeight, cellWidth )" Background="@GetFocusedRowBackground( node.Key )">
                                @if ( TryGetVisibleBar( node.Item, viewRange.Start, viewRange.End, timeSlots.Count, cellWidth, out var barInfo ) )
                                {
                                    var itemStyling = GetItemStyling( node.Item );

                                    <_GanttItemBar CustomClass="@itemStyling.Class"
                                                   Style="@GetBarStyle( barInfo, rowHeight, itemStyling.Style )"
                                                   Background="@itemStyling.Background"
                                                   TextColor="@itemStyling.TextColor"
                                                   Clicked="@(() => OnBarClicked( node.Item ))">
                                        @if ( itemTemplate is not null )
                                        {
                                            @itemTemplate( new GanttItemContext<TItem>( node.Item, node.HasChildren, IsExpanded( node ) ) )
                                        }
                                        else
                                        {
                                            <Div Flex="FlexJustifyContentBetweenAlignItemsCenter" Width="WidthIs100" Height="HeightIs100">
                                                <Span TextOverflow="TextOverflow.Truncate">@GetItemTitle( node.Item )</Span>
                                                @if ( barInfo.ProgressPercentage is not null )
                                                {
                                                    <Span TextSize="TextSizeSmall">@($"{barInfo.ProgressPercentage.Value:0}%")</Span>
                                                }
                                            </Div>
                                        }
                                    </_GanttItemBar>
                                }
                            </_GanttTimeRow>
                        }
                    </_GanttTimelineInner>
                </_GanttTimelineViewport>
            </_GanttTimelinePane>
        </_GanttBody>

        <_GanttItemModal TItem="TItem"
                         @ref="ganttItemModalRef"
                         FirstDayOfWeek="@FirstDayOfWeek"
                         SaveRequested="@SaveImpl"
                         DeleteRequested="@DeleteItemImpl"
                         Closed="@OnItemModalClosed" />
    </CascadingValue>
</Div>

<CascadingValue Value="@this" IsFixed>
    @ChildContent
</CascadingValue>