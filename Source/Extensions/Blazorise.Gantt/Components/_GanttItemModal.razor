@inherits BaseComponent
@typeparam TItem
@using Blazorise.Gantt.Extensions
@using Blazorise.Gantt.Utilities
<Modal @ref="modalRef" Centered Size="ModalSize.Large">
    <ModalContent>
        <ModalHeader>
            <ModalTitle>@ModalTitle</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            <Field>
                <FieldLabel>@Localizer.Localize( Gantt.Localizers?.TitleLocalizer, LocalizationConstants.Title )</FieldLabel>
                <FieldBody>
                    <TextInput @bind-Value="@Title" Autofocus />
                </FieldBody>
            </Field>

            <Field>
                <FieldLabel>@Localizer.Localize( Gantt.Localizers?.DescriptionLocalizer, LocalizationConstants.Description )</FieldLabel>
                <FieldBody>
                    <MemoInput @bind-Value="@Description" Rows="3" />
                </FieldBody>
            </Field>

            <Fields>
                <Field ColumnSize="ColumnSizeIs12OnMobileIs6OnTablet">
                    <FieldLabel>@Localizer.Localize( Gantt.Localizers?.StartLocalizer, LocalizationConstants.Start )</FieldLabel>
                    <FieldBody>
                        <DatePicker TValue="DateOnly" Value="@StartDate" ValueChanged="@OnStartDateChanged" StaticPicker="false" InputMode="DateInputMode.Date" FirstDayOfWeek="@FirstDayOfWeek" />
                    </FieldBody>
                </Field>
                <Field ColumnSize="ColumnSizeIs12OnMobileIs6OnTablet">
                    <FieldLabel>&nbsp;</FieldLabel>
                    <FieldBody>
                        <TimePicker TValue="TimeOnly" Value="@StartTime" ValueChanged="@OnStartTimeChanged" StaticPicker="false" TimeAs24hr />
                    </FieldBody>
                </Field>
            </Fields>

            <Fields>
                <Field ColumnSize="ColumnSizeIs12OnMobileIs6OnTablet">
                    <FieldLabel>@Localizer.Localize( Gantt.Localizers?.EndLocalizer, LocalizationConstants.End )</FieldLabel>
                    <FieldBody>
                        <DatePicker TValue="DateOnly" Value="@EndDate" ValueChanged="@OnEndDateChanged" StaticPicker="false" InputMode="DateInputMode.Date" FirstDayOfWeek="@FirstDayOfWeek" />
                    </FieldBody>
                </Field>
                <Field ColumnSize="ColumnSizeIs12OnMobileIs6OnTablet">
                    <FieldLabel>&nbsp;</FieldLabel>
                    <FieldBody>
                        <TimePicker TValue="TimeOnly" Value="@EndTime" ValueChanged="@OnEndTimeChanged" StaticPicker="false" TimeAs24hr />
                    </FieldBody>
                </Field>
            </Fields>

            @if ( DurationAvailable )
            {
                <Field>
                    <FieldLabel>@Localizer.Localize( Gantt.Localizers?.DurationLocalizer, LocalizationConstants.Duration )</FieldLabel>
                    <FieldBody>
                        <NumericInput TValue="int" Value="@DurationDays" ValueChanged="@OnDurationChanged" Min="1" Step="1" />
                    </FieldBody>
                </Field>
            }

            @if ( customValidationErrors.Count > 0 )
            {
                <Paragraph TextColor="TextColor.Danger" Margin="MarginIs0FromBottom">
                    <UnorderedList Margin="MarginIs0FromBottom">
                        @foreach ( var error in customValidationErrors )
                        {
                            <UnorderedListItem>@error</UnorderedListItem>
                        }
                    </UnorderedList>
                </Paragraph>
            }
        </ModalBody>
        <ModalFooter Flex="FlexJustifyContentBetweenAlignItemsCenter">
            <Div>
                @if ( EditState == GanttEditState.Edit && DeleteCommandVisible )
                {
                    <Button Color="Color.Danger" Outline Clicked="@Delete">
                        <Icon Name="IconName.Delete" Margin="MarginIs1FromEnd" />@Localizer.Localize( Gantt.Localizers?.DeleteLocalizer, LocalizationConstants.Delete )
                    </Button>
                }
            </Div>
            <Div>
                <Button Color="Color.Secondary" Clicked="@Cancel" Margin="MarginIs1FromEnd">@Localizer.Localize( Gantt.Localizers?.CancelLocalizer, LocalizationConstants.Cancel )</Button>
                <Button Color="Color.Primary" Clicked="@Submit">@Localizer.Localize( Gantt.Localizers?.SaveLocalizer, LocalizationConstants.Save )</Button>
            </Div>
        </ModalFooter>
    </ModalContent>
</Modal>