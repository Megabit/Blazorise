@typeparam TNode
@inherits BaseComponent
<div class="@NodeTitleClassNames" style="@NodeTitleStyleNames">
    @if ( ParentTreeViewState.SelectionMode == TreeViewSelectionMode.Multiple )
    {
        <div class="@NodeCheckClassNames" style="@NodeCheckStyleNames">
            <Check TValue="bool" Value="@Checked" ValueChanged="@OnCheckedChanged" Disabled="@NodeState.Disabled" />
        </div>
    }
    <span @ref="@ElementRef" id="@ElementId" class="@ClassNames" style="@NodeContentStyleNames" @onclick="@OnClick"
          draggable="@(ParentTreeView.DragDrop.IsNodeDraggable( NodeState ) ? "true" : null)"
          @ondragstart="@((e) => ParentTreeView.DragDrop.OnDragStart( NodeState, e ))"
          @ondragover="@((e) => ParentTreeView.DragDrop.OnDragOver( NodeState, e ))"
          @ondragover:preventDefault="@ParentTreeView.DragDrop.CanDropOnNode( NodeState )"
          @ondrop="@((e) => ParentTreeView.DragDrop.OnDrop( NodeState, e ))"
          @ondrop:preventDefault="@ParentTreeView.DragDrop.CanDropOnNode( NodeState )"
          @ondragend="@((e) => ParentTreeView.DragDrop.OnDragEnd( NodeState, e ))">
        @ChildContent
    </span>
</div>
