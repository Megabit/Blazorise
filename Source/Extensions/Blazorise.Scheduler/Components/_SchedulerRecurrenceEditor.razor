@using Blazorise.DeepCloner
@using Blazorise.Extensions
@using Blazorise.Scheduler.Utilities
@typeparam TItem
<Fields>
    <Field ColumnSize="ColumnSize.Is3">
        <FieldLabel>Repeat Every</FieldLabel>
        <FieldBody>
            <NumericEdit TValue="int" Min="1" Max="99" Value="@Interval" ValueChanged="@OnIntervalChanged" />
        </FieldBody>
    </Field>
    <Field ColumnSize="ColumnSize.Is9">
        <FieldLabel>&nbsp;</FieldLabel>
        <FieldBody>
            <RadioGroup TValue="SchedulerRecurrencePattern" Name="Pattern" Value="@Pattern" ValueChanged="@OnPatternChanged" Buttons Width="Width.Is100">
                <Radio Value="SchedulerRecurrencePattern.Never">Never</Radio>
                <Radio Value="SchedulerRecurrencePattern.Daily">Day</Radio>
                <Radio Value="SchedulerRecurrencePattern.Weekly">Week</Radio>
                <Radio Value="SchedulerRecurrencePattern.Monthly">Month</Radio>
                <Radio Value="SchedulerRecurrencePattern.Yearly">Year</Radio>
            </RadioGroup>
        </FieldBody>
    </Field>
</Fields>
@if ( Pattern == SchedulerRecurrencePattern.Weekly )
{
    <_SchedulerWeeklyRulePicker ByDay="@ByDay" ByDayChanged="@OnWeeklyRuleOnDayChanged" FirstDayOfWeek="@FirstDayOfWeek" />
}
else if ( Pattern == SchedulerRecurrencePattern.Monthly )
{
    <_SchedulerMonthlyRulePicker Value="@InternalMonthlyRule" ValueChanged="@OnInternalMonthlyRuleChanged"
                                 ByMonthDay="@ByMonthDay" ByMonthDayChanged="@OnMonthlyRuleByMonthDayChanged"
                                 ByMonthWeek="@ByMonthWeek" ByMonthWeekChanged="@OnMonthlyRuleByMonthWeekChanged"
                                 ByMonthWeekDay="@ByMonthWeekDay" ByMonthWeekDayChanged="@OnMonthlyRuleByMonthWeekDayChanged" />
}
@if ( Pattern != SchedulerRecurrencePattern.Never )
{
    <Fields>
        <Field ColumnSize="ColumnSize.Is3">
            <FieldLabel>End</FieldLabel>
            <FieldBody>
                <DatePicker TValue="DateTime ?" Value="@EndDate" ValueChanged="@OnEndDateChanged" StaticPicker="false" InputMode="DateInputMode.Date" FirstDayOfWeek="@FirstDayOfWeek" />
            </FieldBody>
        </Field>
    </Fields>
}
@code {
    public override Task SetParametersAsync( ParameterView parameters )
    {
        if ( parameters.TryGetValue<string>( nameof( RecurrenceRule ), out var paramRecurrenceRule ) && !RecurrenceRule.IsEqual( paramRecurrenceRule ) )
        {
            if ( !string.IsNullOrEmpty( paramRecurrenceRule ) )
            {
                var rule = RecurringRuleParser.Parse( paramRecurrenceRule );

                Pattern = rule.Pattern;
                Interval = rule.Interval;
                EndDate = rule.EndDate;
                Count = rule.Count;
                ByDay = rule.ByDay;
                ByMonthDay = rule.ByMonthDay ?? new List<int> { 1 };
                ByMonthWeek = rule.ByMonthWeek ?? SchedulerMonthWeekPosition.First;
                ByMonthWeekDay = rule.ByMonthWeekDay ?? FirstDayOfWeek;

                if ( Pattern == SchedulerRecurrencePattern.Monthly )
                {
                    InternalMonthlyRule = rule.ByMonthDay?.Any() == true
                        ? "monthly-rule-by-day"
                        : "monthly-rule-by-week";
                }
            }
            else
            {
                Pattern = SchedulerRecurrencePattern.Never;
                Interval = 1;
                EndDate = null;
                Count = null;
                ByDay = new() { DateTime.Today.AddDays( 1 ).DayOfWeek };
                ByMonthDay = new() { 1 };
                ByMonthWeek = SchedulerMonthWeekPosition.First;
                ByMonthWeekDay = FirstDayOfWeek;
            }
        }

        return base.SetParametersAsync( parameters );
    }

    protected Task OnIntervalChanged( int interval )
    {
        Interval = interval;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task OnPatternChanged( SchedulerRecurrencePattern pattern )
    {
        Pattern = pattern;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task OnEndDateChanged( DateTime? endDate )
    {
        EndDate = endDate;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task OnWeeklyRuleOnDayChanged( List<DayOfWeek> byDay )
    {
        ByDay = byDay;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task OnMonthlyRuleByMonthDayChanged( List<int> byMonthDay )
    {
        ByMonthDay = byMonthDay;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task OnMonthlyRuleByMonthWeekChanged( SchedulerMonthWeekPosition? byMonthWeek )
    {
        ByMonthWeek = byMonthWeek;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task OnMonthlyRuleByMonthWeekDayChanged( DayOfWeek? byMonthWeekDay )
    {
        ByMonthWeekDay = byMonthWeekDay;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task OnInternalMonthlyRuleChanged( string value )
    {
        InternalMonthlyRule = value;
        return NotifyRecurrenceRuleChanged();
    }

    protected Task NotifyRecurrenceRuleChanged()
    {
        var rule = new SchedulerRecurrenceRule
        {
            Pattern = Pattern,
            Interval = Interval,
            EndDate = EndDate,
            Count = Count,
            ByDay = ByDay,
        };

        if ( rule.Pattern == SchedulerRecurrencePattern.Monthly )
        {
            if ( InternalMonthlyRule == "monthly-rule-by-day" )
            {
                rule.ByMonthDay = ByMonthDay;

            }
            else
            {
                rule.ByMonthWeek = ByMonthWeek;
                rule.ByMonthWeekDay = ByMonthWeekDay;
            }
        }

        RecurrenceRule = rule.ToRRuleString();
        return RecurrenceRuleChanged.InvokeAsync( RecurrenceRule );
    }

    protected string InternalMonthlyRule = "monthly-rule-by-day";

    protected SchedulerRecurrencePattern Pattern { get; set; }

    protected int Interval { get; set; } = 1;

    protected DateTime? EndDate { get; set; }

    protected int? Count { get; set; }

    protected List<DayOfWeek> ByDay { get; set; }

    protected List<int> ByMonthDay { get; set; }

    protected SchedulerMonthWeekPosition? ByMonthWeek { get; set; }

    protected DayOfWeek? ByMonthWeekDay { get; set; }

    /// <summary>
    /// Defines the first day of the week.
    /// </summary>
    [Parameter] public DayOfWeek FirstDayOfWeek { get; set; }

    [Parameter] public string RecurrenceRule { get; set; }

    [Parameter] public EventCallback<string> RecurrenceRuleChanged { get; set; }
}
