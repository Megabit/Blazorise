<Buttons Width="Width.Is100">
    @for ( var day = FirstDayOfWeek; day < FirstDayOfWeek + 7; day++ )
    {
        var tempDay = day;
        var dayLabel = tempDay.ToString().Substring( 0, 1 );

        <Button Color="Color.Secondary" Outline Active="@(ByDay.Contains( tempDay ))" Clicked="@(() => OnDayClicked( tempDay ))">
            @dayLabel
        </Button>
    }
</Buttons>

@* @for ( var day = FirstDayOfWeek; day < FirstDayOfWeek + 7; day++ )
{
    var tempDay = day;
