@code {
    Task OnDayClicked( DayOfWeek day )
    {
        if ( ByDay.Contains( day ) )
        {
            if ( ByDay.Count > 1 )
            {
                ByDay.Remove( day );
            }
        }
        else
        {
            ByDay.Add( day );
        }

        return Task.CompletedTask;
    }

    private Background GetBackgroundColor( DayOfWeek day )
        => ByDay.Contains( day ) ? Background.Secondary : Background.Default;

    private List<DayOfWeek> ByDay { get; set; } = new() { DateTime.Today.AddDays( 1 ).DayOfWeek };

    [Parameter] public DayOfWeek FirstDayOfWeek { get; set; }
}
