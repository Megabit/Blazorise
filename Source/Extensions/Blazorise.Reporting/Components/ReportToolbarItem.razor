@namespace Blazorise.Reporting
<Button Color="@ResolvedColor" Disabled="@Disabled" Clicked="@OnClicked" title="@Text" aria-label="@Text">
    @if ( ResolvedIcon is not null )
    {
        @if ( ShowCaption )
        {
            <Icon Name="@ResolvedIcon.Value" Margin="Margin.Is2.FromEnd" />
        }
        else
        {
            <Icon Name="@ResolvedIcon.Value" />
        }
    }
    @if ( ShowCaption || ResolvedIcon is null )
    {
        @Text
    }
</Button>