@namespace Blazorise.Reporting.Internal
@inherits BaseReportComponent
@typeparam TValue where TValue : struct

<Field Class="b-report-designer-select-property" Horizontal Margin="MarginIs0FromBottomIs0OnX">
    <FieldLabel ColumnSize="ColumnSizeIs4" TextSize="TextSizeSmall" Padding="PaddingIs1FromEnd" TextOverflow="TextOverflowTruncate">@Label</FieldLabel>
    <FieldBody ColumnSize="ColumnSizeIs8">
        <Select TValue="TValue?" Value="@DisplayValue" ValueChanged="@OnValueChanged" Size="Size.Small">
            @if ( Mixed )
            {
                <SelectItem TValue="TValue?" Value="@((TValue?)null)" Hidden></SelectItem>
            }
            @foreach ( var option in ResolvedOptions )
            {
                <SelectItem TValue="TValue?" Value="@option.Value">@option.Text</SelectItem>
            }
        </Select>
    </FieldBody>
</Field>