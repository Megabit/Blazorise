@namespace Blazorise.Reporting.Internal
@inherits BaseReportComponent

<Field Horizontal Margin="Margin.Is0.FromBottom.Is0.OnX">
    <FieldLabel ColumnSize="ColumnSize.Is4" TextSize="TextSize.Small" Padding="Padding.Is1.FromEnd" TextOverflow="TextOverflow.Truncate">@Label</FieldLabel>
    <FieldBody ColumnSize="ColumnSize.Is8">
        <Addons Size="Size.Small">
            <Addon AddonType="AddonType.Body">
                <Select TValue="string" Value="@SelectedName" ValueChanged="@OnNameChanged" Size="Size.Small">
                    @foreach ( var option in DefaultNamedOptions )
                    {
                        <SelectItem TValue="string" Value="@option.Value">@option.Text</SelectItem>
                    }
                </Select>
            </Addon>
            <Addon AddonType="AddonType.Body">
                <ColorPicker Value="@CustomValue" ValueChanged="@OnCustomChanged" ShowInputField="false" Size="Size.Small" />
            </Addon>
            <Addon AddonType="AddonType.End">
                <Button Color="Color.Light" Clicked="@Clear" Size="Size.Small" aria-label="Clear color">
                    <Icon Name="IconName.Clear" />
                </Button>
            </Addon>
        </Addons>
    </FieldBody>
</Field>