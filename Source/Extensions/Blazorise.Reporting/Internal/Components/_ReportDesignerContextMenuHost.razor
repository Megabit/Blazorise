@namespace Blazorise.Reporting.Internal
@inherits BaseReportComponent
@using Microsoft.AspNetCore.Components.Web

<ContextMenu @ref="contextMenuRef">
    <ContextMenuBody MinWidth="13rem">
        @if ( IsSectionMenu )
        {
            <ContextMenuToolbar>
                <ContextMenuToolbarItem Icon="IconName.Paste" Text="Paste" Disabled="@(!State.CanPasteElement)" Clicked="@OnPasteElementClicked" />
                <ContextMenuToolbarItem Icon="IconName.CheckDouble" Text="Select all" Disabled="@(!State.CanSelectAllSectionElements)" Clicked="@OnSelectAllSectionElementsClicked" />
                <ContextMenuToolbarItem Icon="IconName.Delete" Text="Delete band" Disabled="@(!State.CanDeleteSection)" Clicked="@OnDeleteSectionClicked" />
                <ContextMenuToolbarItem Icon="IconName.List" Text="Properties" Clicked="@OnShowPropertiesClicked" />
            </ContextMenuToolbar>
            <ContextMenuDivider />

            @if ( State.SectionSuppressed )
            {
                <ContextMenuItem ShowCheckbox Checked Clicked="@OnToggleSectionSuppressionClicked">Suppress</ContextMenuItem>
            }
            else
            {
                @if ( State.CanInsertSection )
                {
                    <ContextMenuItem Clicked="@OnInsertSectionBeforeClicked">Insert band before</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnInsertSectionAfterClicked">Insert band after</ContextMenuItem>
                }
                @if ( State.CanInsertGroup )
                {
                    <ContextMenuItem Clicked="@OnInsertGroupClicked">Insert group...</ContextMenuItem>
                }
                @if ( State.CanInsertSubreport )
                {
                    <ContextMenuItem Clicked="@OnInsertSubreportClicked">Insert subreport</ContextMenuItem>
                }
                <ContextMenuItem ShowCheckbox Checked="@State.SectionSuppressed" Clicked="@OnToggleSectionSuppressionClicked">Suppress</ContextMenuItem>
                <ContextMenuItem ShowCheckbox Checked="@State.SectionKeepTogether" Clicked="@OnToggleSectionKeepTogetherClicked">Keep together</ContextMenuItem>
                <ContextMenuItem ShowCheckbox Checked="@State.SectionNewPageBefore" Clicked="@OnToggleSectionNewPageBeforeClicked">New page before</ContextMenuItem>
                <ContextMenuItem ShowCheckbox Checked="@State.SectionNewPageAfter" Clicked="@OnToggleSectionNewPageAfterClicked">New page after</ContextMenuItem>
            }
        }
        else if ( IsElementMenu )
        {
            <ContextMenuToolbar>
                <ContextMenuToolbarItem Icon="IconName.Cut" Text="Cut" Clicked="@OnCutElementClicked" />
                <ContextMenuToolbarItem Icon="IconName.Copy" Text="Copy" Clicked="@OnCopyElementClicked" />
                <ContextMenuToolbarItem Icon="IconName.Paste" Text="Paste" Disabled="@(!State.CanPasteElement)" Clicked="@OnPasteElementClicked" />
                <ContextMenuToolbarItem Icon="IconName.Delete" Text="Delete element" Clicked="@OnDeleteElementClicked" />
                <ContextMenuToolbarItem Icon="IconName.List" Text="Properties" Clicked="@OnShowPropertiesClicked" />
            </ContextMenuToolbar>
            <ContextMenuDivider />

            @if ( State.CanOrderSelectedElements )
            {
                <ContextMenuSubmenu Text="Order">
                    <ContextMenuItem Clicked="@OnBringToFrontClicked">Bring to Front</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnSendToBackClicked">Send to Back</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnMoveForwardClicked">Move Forward</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnMoveBackwardClicked">Move Backward</ContextMenuItem>
                </ContextMenuSubmenu>
            }

            @if ( State.CanAlignOrSizeSelectedElements )
            {
                <ContextMenuSubmenu Text="Align">
                    <ContextMenuItem Clicked="@OnAlignTopsClicked">Tops</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnAlignMiddlesClicked">Middles</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnAlignBottomsClicked">Bottoms</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnAlignBaselineClicked">Baseline</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnAlignLeftsClicked">Lefts</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnAlignCentersClicked">Centers</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnAlignRightsClicked">Rights</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnAlignToGridClicked">To Grid</ContextMenuItem>
                </ContextMenuSubmenu>
                <ContextMenuSubmenu Text="Sizes">
                    <ContextMenuItem Clicked="@OnSizeSameWidthClicked">Same Width</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnSizeSameHeightClicked">Same Height</ContextMenuItem>
                    <ContextMenuItem Clicked="@OnSizeSameSizeClicked">Same Size</ContextMenuItem>
                </ContextMenuSubmenu>
            }

            @if ( State.CanInsertAggregate )
            {
                <ContextMenuItem Clicked="@OnInsertAggregateClicked">Insert aggregate</ContextMenuItem>
            }

            @if ( State.CanEditText )
            {
                <ContextMenuItem Clicked="@OnEditTextClicked">Edit Text</ContextMenuItem>
            }

            @if ( State.CanEditFormula )
            {
                <ContextMenuItem Clicked="@OnEditFormulaClicked">Edit Formula</ContextMenuItem>
            }

            @if ( State.CanEditRunningTotal )
            {
                <ContextMenuItem Clicked="@OnEditRunningTotalClicked">Edit Running Total</ContextMenuItem>
            }

            <ContextMenuItem ShowCheckbox Checked="@State.ElementCanGrow" Clicked="@OnToggleElementCanGrowClicked">Can grow</ContextMenuItem>
            <ContextMenuItem ShowCheckbox Checked="@State.ElementSuppressed" Clicked="@OnToggleElementSuppressionClicked">Suppress</ContextMenuItem>
        }
        else if ( IsCellMenu )
        {
            <ContextMenuToolbar>
                <ContextMenuToolbarItem Icon="IconName.Paste" Text="Paste" Disabled="@(!State.CanPasteElement)" Clicked="@OnPasteElementClicked" />
                <ContextMenuToolbarItem Icon="IconName.List" Text="Properties" Clicked="@OnShowPropertiesClicked" />
            </ContextMenuToolbar>
            <ContextMenuDivider />

            @if ( State.CanShowTableCellMergeOperations )
            {
                @if ( State.CanMergeCellRight )
                {
                    <ContextMenuItem Clicked="@OnMergeCellRightClicked">Merge right</ContextMenuItem>
                }

                @if ( State.CanMergeCellDown )
                {
                    <ContextMenuItem Clicked="@OnMergeCellDownClicked">Merge down</ContextMenuItem>
                }

                @if ( State.CanUnmergeCell )
                {
                    <ContextMenuItem Clicked="@OnUnmergeCellClicked">Unmerge</ContextMenuItem>
                }

                <ContextMenuDivider />
            }

            <ContextMenuSubmenu Text="Insert">
                <ContextMenuItem Disabled="@(!State.CanInsertTableRowAbove)" Clicked="@OnInsertTableRowAboveClicked">Row Above</ContextMenuItem>
                <ContextMenuItem Disabled="@(!State.CanInsertTableRowBelow)" Clicked="@OnInsertTableRowBelowClicked">Row Below</ContextMenuItem>
                <ContextMenuItem Disabled="@(!State.CanInsertTableColumnLeft)" Clicked="@OnInsertTableColumnLeftClicked">Column to Left</ContextMenuItem>
                <ContextMenuItem Disabled="@(!State.CanInsertTableColumnRight)" Clicked="@OnInsertTableColumnRightClicked">Column to Right</ContextMenuItem>
                <ContextMenuItem Disabled="@(!State.CanInsertTableCell)" Clicked="@OnInsertTableCellClicked">Cell</ContextMenuItem>
            </ContextMenuSubmenu>
            <ContextMenuSubmenu Text="Delete">
                <ContextMenuItem Disabled="@(!State.CanDeleteTableRow)" Clicked="@OnDeleteTableRowClicked">Row</ContextMenuItem>
                <ContextMenuItem Disabled="@(!State.CanDeleteTableColumn)" Clicked="@OnDeleteTableColumnClicked">Column</ContextMenuItem>
                <ContextMenuItem Disabled="@(!State.CanDeleteTableCell)" Clicked="@OnDeleteTableCellClicked">Cell</ContextMenuItem>
            </ContextMenuSubmenu>
        }

        <ContextMenuDivider />
        <ContextMenuItem Clicked="@OnCloseClicked">Close</ContextMenuItem>
    </ContextMenuBody>
</ContextMenu>