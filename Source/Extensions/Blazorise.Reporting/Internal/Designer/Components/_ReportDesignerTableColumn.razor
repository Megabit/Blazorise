@namespace Blazorise.Reporting.Internal
@using System.Threading.Tasks
@using Blazorise.Utilities

<td style="@Style">@(Column.Title ?? Column.Field)</td>

@code {
    private readonly StyleBuilder styleBuilder;

    private string Style => styleBuilder.Styles;

    public _ReportDesignerTableColumn()
    {
        styleBuilder = new( BuildStyles );
    }

    public override Task SetParametersAsync( ParameterView parameters )
    {
        if ( parameters.TryGetValue<ReportTableColumnDefinition>( nameof( Column ), out _ ) )
            styleBuilder.Dirty();

        return base.SetParametersAsync( parameters );
    }

    private void BuildStyles( StyleBuilder builder )
    {
        builder.Append( $"width:{Column.Width}px" );
    }

    /// <summary>
    /// Table column definition rendered by the table cell.
    /// </summary>
    [Parameter] public ReportTableColumnDefinition Column { get; set; }
}