@namespace Blazorise.Reporting.Internal
@inherits ReportComponentBase
@using System.Threading.Tasks
@using Blazorise.Utilities
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@implements IAsyncDisposable

<div @key="@ElementKey"
     class="@Class"
     style="@Style"
     @onclick="Clicked"
     @onclick:stopPropagation="@(DesignMode && Editable)"
     @ondblclick="DoubleClicked"
     @ondblclick:preventDefault="@(DesignMode && Editable && CanEditText)"
     @ondblclick:stopPropagation="@(DesignMode && Editable && CanEditText)"
     @oncontextmenu="ContextMenu"
     @oncontextmenu:preventDefault="@(DesignMode && Editable)"
     @oncontextmenu:stopPropagation="@(DesignMode && Editable)"
     @onpointerdown="PointerDown"
     @onpointerdown:preventDefault="@(DesignMode && Editable && !Editing && !TextEditingActive)"
     @onpointerdown:stopPropagation="@(DesignMode && Editable && !Editing)">
    @if ( Editing && CanEditText )
    {
        <textarea @ref="textEditElement"
                  class="b-report-element-text-editor"
                  value="@textEditValue"
                  @oninput="OnTextEditInput"
                  @onblur="CompleteTextEditAsync"
                  @onkeydown="HandleTextEditKeyDownAsync"
                  @onkeydown:stopPropagation="true"
                  @onclick:stopPropagation="true"
                  @ondblclick:stopPropagation="true"
                  @onpointerdown:stopPropagation="true"></textarea>
    }
    else
    {
        @switch ( Element.Type )
        {
            case ReportElementType.Text:
                @GetText()
                break;
            case ReportElementType.Field:
                @GetFieldText()
                break;
            case ReportElementType.Table:
                <_ReportDesignerTable Element="Element" />
                break;
            case ReportElementType.Image:
                <img src="@Element.Source" alt="@ImageAlternativeText" />
                break;
            case ReportElementType.Line:
            case ReportElementType.Rectangle:
            case ReportElementType.PageBreak:
                break;
        }
    }

    @if ( DesignMode && Editable && Selected && !Editing )
    {
        <_ReportDesignerElementResizeHandles NorthWestPointerDown="NorthWestResizeStarted"
                                             NorthPointerDown="NorthResizeStarted"
                                             NorthEastPointerDown="NorthEastResizeStarted"
                                             EastPointerDown="EastResizeStarted"
                                             SouthEastPointerDown="SouthEastResizeStarted"
                                             SouthPointerDown="SouthResizeStarted"
                                             SouthWestPointerDown="SouthWestResizeStarted"
                                             WestPointerDown="WestResizeStarted" />
    }
</div>