@namespace Blazorise.Reporting.Internal
@inherits BaseReportComponent
@using System.Threading.Tasks
@using Blazorise.Utilities
@using Microsoft.AspNetCore.Components.Web

<div class="@Class"
     style="@Style"
     @onclick="Clicked"
     @onclick:stopPropagation
     @oncontextmenu="NonRenderingContextMenu"
     @oncontextmenu:preventDefault
     @oncontextmenu:stopPropagation>
    <button type="button"
            class="b-report-section-rail-toggle"
            title="@ToggleTitle"
            disabled="@(!AllowCollapse || Section.Suppressed)"
            @onclick="ToggleClicked"
            @onclick:stopPropagation>
        @(Section.Suppressed ? "!" : Collapsed ? "+" : "-")
    </button>
    <div class="b-report-section-rail-text">
        <span class="b-report-section-rail-title">@DisplayName</span>
        @if ( ShowDataSource && !string.IsNullOrWhiteSpace( Section.DataSource ) )
        {
            <span class="b-report-section-rail-source">@Section.DataSource</span>
        }
        @if ( Section.Suppressed )
        {
            <span class="b-report-section-rail-status">Suppressed</span>
        }
    </div>
</div>