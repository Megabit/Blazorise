@namespace Blazorise.Reporting.Internal
@inherits BaseReportComponent
@using Microsoft.AspNetCore.Components.Web

<_ReportTreeView Nodes="@ReportDesignerTreeBuilder.BuildFieldsExplorerNodes( DataSources, Definition?.FormulaFields, Definition?.RunningTotals, selectedFormulaFieldName, selectedRunningTotalName )"
                 NodeClicked="@FieldsNodeClicked"
                 NodeDoubleClicked="@FieldsNodeDoubleClicked"
                 NodeContextMenu="@FieldsNodeContextMenu"
                 NodeDragStarted="@FieldsNodeDragStarted"
                 NodeDragEnded="@NodeDragEnded" />

<ContextMenu @ref="formulaFieldContextMenuRef">
    <ContextMenuBody MinWidth="12rem">
        <ContextMenuItem Clicked="@(( object _ ) => NewFormulaFieldClicked( default ))">@NewFormulaFieldContextMenuText</ContextMenuItem>

        @if ( IsFormulaFieldContextMenuTarget )
        {
            <ContextMenuItem Clicked="@(( object _ ) => EditFormulaFieldClicked( default ))">Edit</ContextMenuItem>
            <ContextMenuItem Clicked="@(( object _ ) => RenameFormulaFieldClicked( default ))">Rename</ContextMenuItem>
            <ContextMenuItem Clicked="@(( object _ ) => DeleteFormulaFieldClicked( default ))">Delete</ContextMenuItem>
        }

        <ContextMenuDivider />
        <ContextMenuItem Clicked="@(( object _ ) => CloseFormulaFieldContextMenu())">Close</ContextMenuItem>
    </ContextMenuBody>
</ContextMenu>

<ContextMenu @ref="runningTotalContextMenuRef">
    <ContextMenuBody MinWidth="12rem">
        <ContextMenuItem Clicked="@(( object _ ) => NewRunningTotalClicked( default ))">@NewRunningTotalContextMenuText</ContextMenuItem>

        @if ( IsRunningTotalContextMenuTarget )
        {
            <ContextMenuItem Clicked="@(( object _ ) => EditRunningTotalClicked( default ))">Edit</ContextMenuItem>
            <ContextMenuItem Clicked="@(( object _ ) => RenameRunningTotalClicked( default ))">Rename</ContextMenuItem>
            <ContextMenuItem Clicked="@(( object _ ) => DeleteRunningTotalClicked( default ))">Delete</ContextMenuItem>
        }

        <ContextMenuDivider />
        <ContextMenuItem Clicked="@(( object _ ) => CloseRunningTotalContextMenu())">Close</ContextMenuItem>
    </ContextMenuBody>
</ContextMenu>

<ContextMenu @ref="dataSourceContextMenuRef">
    <ContextMenuBody MinWidth="12rem">
        <ContextMenuItem Clicked="@(( object _ ) => RefreshDataSourceClicked( default ))">Refresh</ContextMenuItem>
        <ContextMenuItem Clicked="@(( object _ ) => DeleteDataSourceClicked( default ))">Delete</ContextMenuItem>
        <ContextMenuDivider />
        <ContextMenuItem Clicked="@(( object _ ) => CloseDataSourceContextMenu())">Close</ContextMenuItem>
    </ContextMenuBody>
</ContextMenu>

<_ReportDesignerFormulaFieldNameDialog @ref="formulaFieldNameDialogRef"
                                       Confirmed="@FormulaFieldNameConfirmed" />
<_ReportDesignerFormulaFieldNameDialog @ref="runningTotalNameDialogRef"
                                       Confirmed="@RunningTotalNameConfirmed" />
<_ReportDesignerFormulaDialog @ref="formulaDialogRef"
                              Definition="@Definition"
                              Data="@Data"
                              Confirmed="@FormulaFieldFormulaConfirmed" />
<_ReportDesignerRunningTotalDialog @ref="runningTotalDialogRef"
                                   Definition="@Definition"
                                   Data="@Data"
                                   Confirmed="@RunningTotalDialogConfirmed" />