@namespace Blazorise.Reporting.Internal
@inherits ReportComponentBase
@using System
@using Microsoft.AspNetCore.Components.Web

@if ( ReportSelected )
{
    <Div Margin="Margin.Is3.FromBottom">
        <h6>Report properties</h6>
        <Field Margin="Margin.Is2.FromBottom">
            <label class="b-report-designer-option">
                <input type="checkbox" checked="@SnapToGrid" @onchange="SnapToGridChanged" />
                Snap to grid
            </label>
        </Field>
        <_ReportDesignerNumberProperty Label="Page width" Value="@Definition.Page.Width" Changed="@(value => UpdateReportPage( page => page.Width = Math.Max( 1, value ) ))" />
        <_ReportDesignerNumberProperty Label="Page height" Value="@Definition.Page.Height" Changed="@(value => UpdateReportPage( page => page.Height = Math.Max( 1, value ) ))" />
    </Div>
}

@if ( SelectedSection is not null && SelectedElement is null )
{
    <Div Margin="Margin.Is3.FromBottom">
        <h6>Band properties</h6>
        <_ReportDesignerPropertyGroup Title="Status">
            <Field Margin="Margin.Is2.FromBottom">
                <label class="b-report-designer-option">
                    <input type="checkbox" checked="@SelectedSection.Suppressed" @onchange="@(eventArgs => UpdateSelectedSectionSuppression( eventArgs.Value is bool value && value ))" />
                    Suppress
                </label>
            </Field>
        </_ReportDesignerPropertyGroup>

        @if ( !SelectedSection.Suppressed )
        {
            <_ReportDesignerPropertyGroup Title="General">
                <_ReportDesignerTextProperty Label="Name" Value="@SelectedSection.Name" Changed="@(value => UpdateSelectedSection( section => section.Name = value ))" />
                <_ReportDesignerTextProperty Label="Data source" Value="@SelectedSection.DataSource" Changed="@(value => UpdateSelectedSection( section => section.DataSource = value ))" />
                @if ( SelectedSection.Type is ReportSectionType.Group or ReportSectionType.GroupHeader )
                {
                    <_ReportDesignerTextProperty Label="Group by" Value="@SelectedSection.GroupBy" Changed="@(value => UpdateSelectedSection( section => section.GroupBy = value ))" />
                }
            </_ReportDesignerPropertyGroup>
            <_ReportDesignerPropertyGroup Title="Layout">
                <_ReportDesignerNumberProperty Label="Height" Value="@SelectedSection.Height" Changed="@(value => UpdateSelectedSection( section => section.Height = Math.Max( GetMinimumSectionHeight?.Invoke( section ) ?? 8, value ) ))" />
            </_ReportDesignerPropertyGroup>
            <_ReportDesignerPropertyGroup Title="Advanced">
                <_ReportDesignerTextProperty Label="Custom CSS" Value="@SelectedSection.Style" Changed="@(value => UpdateSelectedSection( section => section.Style = value ))" />
            </_ReportDesignerPropertyGroup>
            <Div Flex="Flex.Wrap" Gap="Gap.Is2" Margin="Margin.Is3.FromTop">
                @if ( CanInsertSection )
                {
                    <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => InsertSection( false ))">Insert before</Button>
                    <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => InsertSection( true ))">Insert after</Button>
                }
                @if ( CanInsertGroup )
                {
                    <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => InsertGroup())">Insert group...</Button>
                }
                @if ( ReportDefinitionHelper.CanDeleteSection( SelectedSection ) )
                {
                    <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => DeleteSelectedSection())">Delete band</Button>
                }
            </Div>
        }
    </Div>
}

@if ( SelectedElement is not null && !SelectedElementSuppressed )
{
    <Div Margin="Margin.Is3.FromTop">
        <h6>Element properties</h6>
        <_ReportDesignerPropertyGroup Title="General">
            <_ReportDesignerTextProperty Label="Name" Value="@SelectedElement.Name" Changed="@(value => UpdateSelectedElement( element => element.Name = value ))" />
        </_ReportDesignerPropertyGroup>

        @if ( SelectedElement.Type is ReportElementType.Text or ReportElementType.Field or ReportElementType.Image )
        {
            var contentGroupTitle = SelectedElement.Type == ReportElementType.Field ? "Data" : "Content";

            <_ReportDesignerPropertyGroup Title="@contentGroupTitle">
                @switch ( SelectedElement.Type )
                {
                    case ReportElementType.Text:
                        <_ReportDesignerTextProperty Label="Text" Value="@SelectedElement.Text" Changed="@(value => UpdateSelectedElement( element => element.Text = value ))" />
                        break;
                    case ReportElementType.Field:
                        <_ReportDesignerTextProperty Label="Expression" Value="@ReportExpressionFormatter.FormatFieldExpression( Definition, SelectedElement )" ReadOnly />
                        @if ( SelectedElement.Aggregate is not null )
                        {
                            <_ReportDesignerTextProperty Label="Aggregate" Value="@ReportAggregateResolver.GetFunctionDisplayName( SelectedElement.Aggregate.Function )" ReadOnly />
                        }
                        <_ReportDesignerTextProperty Label="Format" Value="@SelectedElement.Format" Changed="@(value => UpdateSelectedElement( element => element.Format = value ))" />
                        break;
                    case ReportElementType.Image:
                        <_ReportDesignerTextProperty Label="Source" Value="@SelectedElement.Source" Changed="@(value => UpdateSelectedElement( element => element.Source = value ))" />
                        <_ReportDesignerTextProperty Label="Alt text" Value="@SelectedElement.Text" Changed="@(value => UpdateSelectedElement( element => element.Text = value ))" />
                        break;
                }
            </_ReportDesignerPropertyGroup>
        }

        <_ReportDesignerPropertyGroup Title="Position and size">
            <_ReportDesignerNumberProperty Label="X" Value="@SelectedElement.X" Changed="@(value => UpdateSelectedElement( element => element.X = value ))" />
            <_ReportDesignerNumberProperty Label="Y" Value="@SelectedElement.Y" Changed="@(value => UpdateSelectedElement( element => element.Y = value ))" />
            <_ReportDesignerNumberProperty Label="Width" Value="@SelectedElement.Width" Changed="@(value => UpdateSelectedElement( element => element.Width = value ))" />
            <_ReportDesignerNumberProperty Label="Height" Value="@SelectedElement.Height" Changed="@(value => UpdateSelectedElement( element => element.Height = value ))" />
        </_ReportDesignerPropertyGroup>

        @if ( SelectedElement.Type is not ReportElementType.Image and not ReportElementType.Line and not ReportElementType.Rectangle and not ReportElementType.PageBreak )
        {
            var font = ReportElementDefinitionHelper.EnsureFont( SelectedElement );

            <_ReportDesignerPropertyGroup Title="Text">
                <_ReportDesignerTextProperty Label="Font family" Value="@font.Family" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureFont( element ).Family = value ))" />
                <_ReportDesignerNullableNumberProperty Label="Font size" Value="@font.Size" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureFont( element ).Size = ReportElementDefinitionHelper.NormalizeNullablePositiveNumber( value ) ))" />
                <_ReportDesignerColorProperty Label="Font color" Value="@font.Color" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureFont( element ).Color = value ))" />
                <Field Margin="Margin.Is2.FromBottom">
                    <FieldLabel>Alignment</FieldLabel>
                    <Select TValue="TextAlignment" Value="@font.Alignment" ValueChanged="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureFont( element ).Alignment = value ))">
                        @foreach ( var option in Enum.GetValues<TextAlignment>() )
                        {
                            <SelectItem TValue="TextAlignment" Value="@option">@option.ToString()</SelectItem>
                        }
                    </Select>
                </Field>
                <_ReportDesignerCheckboxProperty Label="Bold" Value="@font.Bold" Changed="@(eventArgs => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureFont( element ).Bold = eventArgs.Value is bool value && value ))" />
                <_ReportDesignerCheckboxProperty Label="Italic" Value="@font.Italic" Changed="@(eventArgs => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureFont( element ).Italic = eventArgs.Value is bool value && value ))" />
                <_ReportDesignerCheckboxProperty Label="Underline" Value="@font.Underline" Changed="@(eventArgs => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureFont( element ).Underline = eventArgs.Value is bool value && value ))" />
            </_ReportDesignerPropertyGroup>
        }

        @{
            var appearance = ReportElementDefinitionHelper.EnsureAppearance( SelectedElement );
            var border = ReportElementDefinitionHelper.EnsureBorder( SelectedElement );
        }

        <_ReportDesignerPropertyGroup Title="Appearance">
            <_ReportDesignerColorProperty Label="Fill color" Value="@appearance.BackgroundColor" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureAppearance( element ).BackgroundColor = value ))" />
            <_ReportDesignerColorProperty Label="Border color" Value="@border.Color" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureBorder( element ).Color = value ))" />
            <_ReportDesignerNullableNumberProperty Label="Border width" Value="@border.Width" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureBorder( element ).Width = ReportElementDefinitionHelper.NormalizeNullablePositiveNumber( value ) ))" />
            <_ReportDesignerNullableNumberProperty Label="Corner radius" Value="@border.Radius" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureBorder( element ).Radius = ReportElementDefinitionHelper.NormalizeNullablePositiveNumber( value ) ))" />
            <_ReportDesignerNullableNumberProperty Label="Opacity" Value="@appearance.Opacity" Changed="@(value => UpdateSelectedElement( element => ReportElementDefinitionHelper.EnsureAppearance( element ).Opacity = ReportElementDefinitionHelper.NormalizeOpacity( value ) ))" />
        </_ReportDesignerPropertyGroup>

        <_ReportDesignerPropertyGroup Title="Advanced">
            <_ReportDesignerTextProperty Label="CSS classes" Value="@SelectedElement.Class" Changed="@(value => UpdateSelectedElement( element => element.Class = value ))" />
            <_ReportDesignerTextProperty Label="Custom CSS" Value="@SelectedElement.Style" Changed="@(value => UpdateSelectedElement( element => element.Style = value ))" />
        </_ReportDesignerPropertyGroup>
    </Div>

    <Div Margin="Margin.Is3.FromTop">
        <h6>Selected element</h6>
        <Div Flex="Flex.Wrap" Gap="Gap.Is2">
            <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => MoveSelectedElement( -8, 0, 0, 0 ))">Left</Button>
            <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => MoveSelectedElement( 0, -8, 0, 0 ))">Up</Button>
            <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => MoveSelectedElement( 0, 8, 0, 0 ))">Down</Button>
            <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => MoveSelectedElement( 8, 0, 0, 0 ))">Right</Button>
            <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => MoveSelectedElement( 0, 0, 16, 0 ))">Wider</Button>
            <Button Color="Color.Light" Clicked="@((MouseEventArgs _) => MoveSelectedElement( 0, 0, 0, 8 ))">Taller</Button>
        </Div>
    </Div>
}

@if ( !HasSelection )
{
    <Paragraph TextColor="TextColor.Secondary">Select a band or report element to edit its properties.</Paragraph>
}