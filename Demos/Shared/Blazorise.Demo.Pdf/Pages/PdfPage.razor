@page "/tests/pdf"
@using System
@using System.Threading.Tasks
@inject IPdfGenerator PdfGenerator

<PdfDocument @ref="declarativeDocument" Title="Declarative PDF" PageSize="PdfPageSize.A4">
    <PdfPage>
        <PdfText Text="Invoice summary" X="48" Y="48" Width="260" Height="32" FontSize="22" Bold TextColor="#0d6efd" />
        <PdfText Text="Generated by Blazorise.Pdf declarative components." X="48" Y="82" Width="360" Height="18" FontSize="11" />
        <PdfRectangle X="420" Y="48" Width="96" Height="48" BorderColor="#0d6efd" BackgroundColor="#eef5ff" />
        <PdfText Text="BLZ" X="444" Y="64" Width="48" Height="20" FontSize="18" Bold TextAlignment="PdfTextAlignment.Center" TextColor="#0d6efd" />
        <PdfLine X="48" Y="122" Width="468" Height="0" BorderColor="#222222" />
        <PdfTable X="48" Y="152" Width="468" Height="96" BorderColor="#999999">
            <PdfTableRow Height="24">
                <PdfTableCell Width="120">
                    <PdfText Text="Number" Bold />
                </PdfTableCell>
                <PdfTableCell Width="228">
                    <PdfText Text="Description" Bold />
                </PdfTableCell>
                <PdfTableCell Width="120">
                    <PdfText Text="Total" Bold TextAlignment="PdfTextAlignment.End" />
                </PdfTableCell>
            </PdfTableRow>
            <PdfTableRow Height="24">
                <PdfTableCell Width="120">
                    <PdfText Text="INV-1001" />
                </PdfTableCell>
                <PdfTableCell Width="228">
                    <PdfText Text="Northwind Traders" />
                </PdfTableCell>
                <PdfTableCell Width="120">
                    <PdfText Text="$1,240.50" TextAlignment="PdfTextAlignment.End" />
                </PdfTableCell>
            </PdfTableRow>
        </PdfTable>
    </PdfPage>
</PdfDocument>

<Row>
    <Column>
        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>PDF</CardTitle>
            </CardHeader>
            <CardBody>
                <Div Flex="Flex.Row" Gap="Gap.Is2" Margin="Margin.Is3.FromBottom">
                    <Button Color="Color.Primary" Clicked="@GenerateDeclarativeAsync">Declarative PDF</Button>
                    <Button Color="Color.Secondary" Clicked="@GenerateImperativeAsync">Imperative PDF</Button>
                </Div>

                @if ( !string.IsNullOrWhiteSpace( previewSource ) )
                {
                    <PdfViewerContainer Height="Height.Rem( 46 )">
                        <PdfViewerToolbar />
                        <PdfViewer Source="@previewSource" />
                    </PdfViewerContainer>
                }
            </CardBody>
        </Card>
    </Column>
</Row>

@code {
    private PdfDocument declarativeDocument;

    private string previewSource;

    protected override async Task OnAfterRenderAsync( bool firstRender )
    {
        if ( firstRender )
            await GenerateDeclarativeAsync();
    }

    private async Task GenerateDeclarativeAsync()
    {
        if ( declarativeDocument?.Definition is null )
            return;

        await GeneratePreviewAsync( declarativeDocument.Definition, "declarative.pdf" );
    }

    private Task GenerateImperativeAsync()
    {
        PdfDocumentDefinition document = PdfDocumentBuilder.Create()
            .Title( "Imperative PDF" )
            .Page( page =>
            {
                page.Text( "Imperative PDF", 48, 48, 240, 32 )
                    .FontSize( 22 )
                    .Bold()
                    .TextColor( "#0d6efd" );

                page.Text( "Generated with PdfDocumentBuilder.", 48, 82, 320, 18 )
                    .FontSize( 11 );

                page.Rectangle( 48, 122, 468, 72 )
                    .BorderColor( "#999999" )
                    .BackgroundColor( "#f8f9fa" );

                page.Text( "This definition was built without Razor components.", 68, 148, 360, 24 );
            } )
            .Build();

        return GeneratePreviewAsync( document, "imperative.pdf" );
    }

    private async Task GeneratePreviewAsync( PdfDocumentDefinition document, string fileName )
    {
        PdfRenderResult result = await PdfGenerator.GenerateAsync( document, new()
        {
            FileName = fileName,
        } );

        previewSource = $"data:{result.ContentType};base64,{Convert.ToBase64String( result.Content )}";
        StateHasChanged();
    }
}