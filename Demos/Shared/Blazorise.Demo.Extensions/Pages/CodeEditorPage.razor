@page "/tests/codeeditor"

<Row>
    <Column>
        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>Code editor</CardTitle>
            </CardHeader>
            <CardBody>
                <Fields>
                    <Field>
                        <FieldLabel>Language</FieldLabel>
                        <FieldBody>
                            <Select TValue="string" @bind-Value="@language">
                                <SelectItem TValue="string" Value="@CodeEditorLanguage.CSharp">C#</SelectItem>
                                <SelectItem TValue="string" Value="@CodeEditorLanguage.Json">JSON</SelectItem>
                                <SelectItem TValue="string" Value="@CodeEditorLanguage.JavaScript">JavaScript</SelectItem>
                                <SelectItem TValue="string" Value="@CodeEditorLanguage.Markdown">Markdown</SelectItem>
                            </Select>
                        </FieldBody>
                    </Field>
                    <Field>
                        <FieldLabel>Theme</FieldLabel>
                        <FieldBody>
                            <Select TValue="string" @bind-Value="@theme">
                                <SelectItem TValue="string" Value="@CodeEditorTheme.VisualStudio">Light</SelectItem>
                                <SelectItem TValue="string" Value="@CodeEditorTheme.VisualStudioDark">Dark</SelectItem>
                                <SelectItem TValue="string" Value="@CodeEditorTheme.HighContrastDark">High contrast</SelectItem>
                            </Select>
                        </FieldBody>
                    </Field>
                    <Field>
                        <FieldBody>
                            <Check TValue="bool" @bind-Value="@wordWrap">Word wrap</Check>
                        </FieldBody>
                    </Field>
                    <Field>
                        <FieldBody>
                            <Check TValue="bool" @bind-Value="@minimap">Minimap</Check>
                        </FieldBody>
                    </Field>
                    <Field>
                        <FieldBody>
                            <Check TValue="bool" @bind-Value="@readOnly">Read only</Check>
                        </FieldBody>
                    </Field>
                </Fields>
            </CardBody>
            <CardBody>
                <CodeEditor @ref="@codeEditorRef"
                            @bind-Value="@sourceCode"
                            Language="@language"
                            Theme="@theme"
                            ReadOnly="@readOnly"
                            EditorOptions="@EditorOptions"
                            Diagnostics="@diagnostics"
                            MinHeight="420px"
                            Ready="@OnReady"
                            EditorFocus="@OnFocus"
                            EditorBlur="@OnBlur" />
            </CardBody>
            <CardFooter>
                <Buttons>
                    <Button Color="Color.Primary" Clicked="@FormatDocumentAsync">Format</Button>
                    <Button Color="Color.Secondary" Clicked="@FocusEditorAsync">Focus</Button>
                    <Button Color="Color.Secondary" Clicked="@LayoutEditorAsync">Layout</Button>
                    <Button Color="Color.Warning" Clicked="@ToggleDiagnostics">Diagnostics</Button>
                </Buttons>
                <Span Margin="Margin.Is3.FromStart">@editorStatus</Span>
            </CardFooter>
        </Card>

        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>Code editor validation</CardTitle>
            </CardHeader>
            <CardBody>
                <Validations @ref="@validations" Mode="ValidationMode.Manual">
                    <Validation Validator="@ValidationRule.IsNotEmpty">
                        <Field>
                            <FieldLabel>Script</FieldLabel>
                            <FieldBody>
                                <CodeEditor @bind-Value="@validationCode"
                                            Language="@CodeEditorLanguage.JavaScript"
                                            Theme="@theme"
                                            MinHeight="180px"
                                            EditorOptions="@ValidationEditorOptions">
                                    <Feedback>
                                        <ValidationError>Please enter script content.</ValidationError>
                                    </Feedback>
                                </CodeEditor>
                            </FieldBody>
                        </Field>
                    </Validation>
                    <Button Color="Color.Primary" Clicked="@ValidateAsync">Submit</Button>
                </Validations>
            </CardBody>
        </Card>

        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>Formula editor</CardTitle>
            </CardHeader>
            <CardBody>
                <Field>
                    <FieldLabel>Datasource</FieldLabel>
                    <FieldBody>
                        <Select TValue="string" @bind-Value="@selectedDataSource">
                            <SelectItem TValue="string" Value="@CustomerDataSource">Customer</SelectItem>
                            <SelectItem TValue="string" Value="@OrderDataSource">Order</SelectItem>
                        </Select>
                    </FieldBody>
                </Field>
                <CodeEditor @ref="@formulaEditorRef"
                            @bind-Value="@formula"
                            Language="@FormulaLanguage"
                            Theme="@theme"
                            MinHeight="240px"
                            EditorOptions="@FormulaEditorOptions"
                            CompletionItems="@FormulaCompletionItems"
                            CompletionTriggerCharacters="@formulaTriggerCharacters"
                            Diagnostics="@FormulaDiagnostics">
                    <CodeEditorCustomLanguage Id="@FormulaLanguage" Aliases="@formulaLanguageAliases" Extensions="@formulaLanguageExtensions">
                        <CodeEditorTokenizer IgnoreCase>
                            <CodeEditorToken Pattern="@FormulaKeywordPattern" Token="keyword" />
                            <CodeEditorToken Pattern="@FormulaFunctionPattern" Token="function" />
                            <CodeEditorToken Pattern="@FormulaFieldPattern" Token="variable" />
                            <CodeEditorToken Pattern="@FormulaStringPattern" Token="string" />
                            <CodeEditorToken Pattern="@FormulaCommentPattern" Token="comment" />
                            <CodeEditorToken Pattern="@FormulaNumberPattern" Token="number" />
                            <CodeEditorToken Pattern="@FormulaOperatorPattern" Token="operator" />
                        </CodeEditorTokenizer>
                    </CodeEditorCustomLanguage>
                </CodeEditor>
            </CardBody>
            <CardFooter>
                <Button Color="Color.Secondary" Clicked="@RefreshFormulaCompletionsAsync">Refresh completions</Button>
                <Span Margin="Margin.Is3.FromStart">@formulaStatus</Span>
            </CardFooter>
        </Card>
    </Column>
</Row>

@code {
    private const string FormulaLanguage = "formula";
    private const string CustomerDataSource = "customer";
    private const string OrderDataSource = "order";
    private const string FormulaKeywordPattern = @"\b(if|then|else|and|or|not|true|false)\b";
    private const string FormulaFunctionPattern = @"\b(Sum|Count|Average|Minimum|Maximum|ToText|Date|DateTime)\b";
    private const string FormulaFieldPattern = @"\{[A-Za-z0-9_.]+\}";
    private const string FormulaStringPattern = @"""[^""]*""";
    private const string FormulaCommentPattern = @"//.*$";
    private const string FormulaNumberPattern = @"[0-9]+(\.[0-9]+)?";
    private const string FormulaOperatorPattern = @"[\+\-\*/=<>]+";

    private CodeEditor codeEditorRef;
    private CodeEditor formulaEditorRef;
    private Validations validations;

    private string language = CodeEditorLanguage.CSharp;
    private string theme = CodeEditorTheme.VisualStudioDark;
    private bool wordWrap = true;
    private bool minimap = true;
    private bool readOnly;
    private bool showDiagnostics = true;
    private string editorStatus = "Ready";
    private string validationCode;
    private string selectedDataSource = CustomerDataSource;
    private string formulaStatus = "Completion items are based on the selected datasource.";
    private string formula = """
if {Customer.IsActive} then
    ToText({Customer.Name})
else
    "Inactive"
""";

    private readonly IReadOnlyList<string> formulaLanguageAliases = new[] { "Formula" };
    private readonly IReadOnlyList<string> formulaLanguageExtensions = new[] { ".formula" };
    private readonly IReadOnlyList<string> formulaTriggerCharacters = new[] { "{", ".", "(" };

    private string sourceCode = """
using System;

public class Greeting
{
    public string CreateMessage( string name )
    {
        return $"Hello, {name}!";
    }
}
""";

    private IReadOnlyList<CodeEditorDiagnostic> diagnostics => showDiagnostics
        ? new[]
        {
            new CodeEditorDiagnostic
            {
                Severity = CodeEditorDiagnosticSeverity.Warning,
                Message = "Demo diagnostic marker.",
                StartLineNumber = 5,
                StartColumn = 19,
                EndLineNumber = 5,
                EndColumn = 32
            }
        }
        : Array.Empty<CodeEditorDiagnostic>();

    private CodeEditorOptions EditorOptions => new()
    {
        AutomaticLayout = true,
        Minimap = minimap,
        WordWrap = wordWrap,
        FormatOnPaste = true,
        FormatOnType = true,
        TabSize = 4
    };

    private CodeEditorOptions ValidationEditorOptions => new()
    {
        AutomaticLayout = true,
        Minimap = false,
        WordWrap = true,
        TabSize = 2
    };

    private CodeEditorOptions FormulaEditorOptions => new()
    {
        AutomaticLayout = true,
        Minimap = false,
        WordWrap = true,
        TabSize = 4
    };

    private IReadOnlyList<CodeEditorCompletionItem> FormulaCompletionItems => BuildFormulaCompletionItems();

    private IReadOnlyList<CodeEditorDiagnostic> FormulaDiagnostics => formula?.Contains( "{Order.", StringComparison.OrdinalIgnoreCase ) == true && selectedDataSource == CustomerDataSource
        ? new[]
        {
            new CodeEditorDiagnostic
            {
                Severity = CodeEditorDiagnosticSeverity.Warning,
                Message = "This field belongs to the Order datasource.",
                StartLineNumber = 1,
                StartColumn = Math.Max( 1, formula.IndexOf( "{Order.", StringComparison.OrdinalIgnoreCase ) + 1 ),
                EndLineNumber = 1,
                EndColumn = Math.Max( 1, formula.IndexOf( "{Order.", StringComparison.OrdinalIgnoreCase ) + 8 )
            }
        }
        : Array.Empty<CodeEditorDiagnostic>();

    private Task FormatDocumentAsync()
    {
        return codeEditorRef?.FormatDocumentAsync() ?? Task.CompletedTask;
    }

    private Task FocusEditorAsync()
    {
        return codeEditorRef?.Focus() ?? Task.CompletedTask;
    }

    private Task LayoutEditorAsync()
    {
        return codeEditorRef?.LayoutAsync() ?? Task.CompletedTask;
    }

    private Task ValidateAsync()
    {
        return validations.ValidateAll();
    }

    private Task OnReady( CodeEditorReadyEventArgs eventArgs )
    {
        editorStatus = $"Initialized: {eventArgs.ElementId}";

        return Task.CompletedTask;
    }

    private Task OnFocus()
    {
        editorStatus = "Focused";

        return Task.CompletedTask;
    }

    private Task OnBlur()
    {
        editorStatus = "Blurred";

        return Task.CompletedTask;
    }

    private void ToggleDiagnostics()
    {
        showDiagnostics = !showDiagnostics;
    }

    private async Task RefreshFormulaCompletionsAsync()
    {
        if ( formulaEditorRef is not null )
            await formulaEditorRef.SetCompletionItemsAsync( FormulaCompletionItems );

        formulaStatus = $"Completion items refreshed for {selectedDataSource}.";
    }

    private IReadOnlyList<CodeEditorCompletionItem> BuildFormulaCompletionItems()
    {
        List<CodeEditorCompletionItem> items = new();

        items.AddRange( new[]
        {
            new CodeEditorCompletionItem { Label = "if then else", InsertText = "if ${1:condition} then\r\n    ${2:value}\r\nelse\r\n    ${3:value}", Kind = CodeEditorCompletionItemKind.Snippet, Detail = "Conditional expression", InsertTextRules = CodeEditorCompletionItemInsertTextRule.InsertAsSnippet },
            new CodeEditorCompletionItem { Label = "Sum", InsertText = "Sum(${1:field})", Kind = CodeEditorCompletionItemKind.Function, Detail = "Aggregate function", InsertTextRules = CodeEditorCompletionItemInsertTextRule.InsertAsSnippet },
            new CodeEditorCompletionItem { Label = "Count", InsertText = "Count(${1:field})", Kind = CodeEditorCompletionItemKind.Function, Detail = "Aggregate function", InsertTextRules = CodeEditorCompletionItemInsertTextRule.InsertAsSnippet },
            new CodeEditorCompletionItem { Label = "ToText", InsertText = "ToText(${1:value})", Kind = CodeEditorCompletionItemKind.Function, Detail = "Converts a value to text", InsertTextRules = CodeEditorCompletionItemInsertTextRule.InsertAsSnippet },
            new CodeEditorCompletionItem { Label = "and", InsertText = "and", Kind = CodeEditorCompletionItemKind.Operator },
            new CodeEditorCompletionItem { Label = "or", InsertText = "or", Kind = CodeEditorCompletionItemKind.Operator }
        } );

        string[] fields = selectedDataSource == OrderDataSource
            ? new[] { "Order.Id", "Order.Number", "Order.Total", "Order.CreatedAt", "Order.Status" }
            : new[] { "Customer.Id", "Customer.Name", "Customer.Email", "Customer.IsActive", "Customer.CreatedAt" };

        items.AddRange( fields.Select( field => new CodeEditorCompletionItem
        {
            Label = $"{{{field}}}",
            InsertText = $"{{{field}}}",
            Kind = CodeEditorCompletionItemKind.Field,
            Detail = "Datasource field",
            SortText = $"0_{field}"
        } ) );

        return items;
    }
}