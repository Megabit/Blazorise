@page "/tests/utilities/dock-layout"

<Row>
    <Column>
        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>Dock Layout</CardTitle>
            </CardHeader>
            <CardBody>
                <CardText>
                    Dock panels can be resized, moved by dragging their headers, and grouped as tabs when multiple panels share the same dock position.
                </CardText>
            </CardBody>
            <CardBody>
                <DockLayout @bind-State="@dockState" Height="Height.Rem( 34 )" Border="Border.Is1.Rounded">
                    <DockPanel Name="explorer" Caption="Explorer" Dock="DockPanelPosition.Left" Size="16rem" MinSize="2rem" Resizable>
                        <DockPanelHeader>
                            <Strong>Explorer</Strong>
                        </DockPanelHeader>
                        <DockPanelBody>
                            <ListGroup Flush>
                                <ListGroupItem>Documents</ListGroupItem>
                                <ListGroupItem>Reports</ListGroupItem>
                                <ListGroupItem>Templates</ListGroupItem>
                                <ListGroupItem>Data Sources</ListGroupItem>
                            </ListGroup>
                        </DockPanelBody>
                    </DockPanel>

                    <DockPanel Name="toolbar" Caption="Toolbar" Dock="DockPanelPosition.Top" Size="4rem" Movable="false">
                        <DockPanelBody Padding="Padding.Is2">
                            <Div Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2">
                                <Button Color="Color.Primary" Size="Size.Small">
                                    <Icon Name="IconName.Save" />
                                    Save
                                </Button>
                                <Button Color="Color.Light" Size="Size.Small">
                                    <Icon Name="IconName.Sync" />
                                    Refresh
                                </Button>
                                <Button Color="Color.Light" Size="Size.Small">
                                    <Icon Name="IconName.Search" />
                                    Find
                                </Button>
                            </Div>
                        </DockPanelBody>
                    </DockPanel>

                    <DockContent Padding="Padding.Is4" Background="Background.Light">
                        <Card>
                            <CardHeader>
                                <CardTitle>Design Surface</CardTitle>
                            </CardHeader>
                            <CardBody>
                                <Paragraph>
                                    The center content stays independent from docked panels, so consumers can place editors, dashboards, document previews, or designer surfaces here.
                                </Paragraph>
                                <Alert Color="Color.Info" Visible>
                                    Drag panel headers to another edge of the layout. Drop a panel onto the same edge as another panel to create a tabbed group.
                                </Alert>
                            </CardBody>
                        </Card>
                    </DockContent>

                    <DockPanel Name="properties" Caption="Properties" Dock="DockPanelPosition.Right" Size="18rem" MinSize="2rem" Resizable>
                        <DockPanelHeader>
                            <Strong>Properties</Strong>
                        </DockPanelHeader>
                        <DockPanelBody>
                            <Field>
                                <FieldLabel>Name</FieldLabel>
                                <TextInput Value="Invoice summary" />
                            </Field>
                            <Field>
                                <FieldLabel>Mode</FieldLabel>
                                <Select TValue="string" Value="@("Design")">
                                    <SelectItem Value="@("Design")">Design</SelectItem>
                                    <SelectItem Value="@("Preview")">Preview</SelectItem>
                                </Select>
                            </Field>
                        </DockPanelBody>
                        <DockPanelFooter>
                            <Button Color="Color.Primary" Size="Size.Small">Apply</Button>
                        </DockPanelFooter>
                    </DockPanel>

                    <DockPanel Name="report-explorer" Caption="Report Explorer" Dock="DockPanelPosition.Right" Size="18rem" MinSize="2rem" Resizable>
                        <DockPanelHeader>
                            <Strong>Report Explorer</Strong>
                        </DockPanelHeader>
                        <DockPanelBody>
                            <ListGroup Flush>
                                <ListGroupItem>Invoice report</ListGroupItem>
                                <ListGroupItem>Report header</ListGroupItem>
                                <ListGroupItem>Page header</ListGroupItem>
                                <ListGroupItem>Detail</ListGroupItem>
                                <ListGroupItem>Report footer</ListGroupItem>
                            </ListGroup>
                        </DockPanelBody>
                    </DockPanel>

                    <DockPanel Name="output" Caption="Output" Dock="DockPanelPosition.Bottom" Size="6rem" Resizable>
                        <DockPanelHeader>
                            <Strong>Output</Strong>
                        </DockPanelHeader>
                        <DockPanelBody>
                            Ready. No errors or warnings.
                        </DockPanelBody>
                    </DockPanel>
                </DockLayout>
            </CardBody>
        </Card>
        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>Advanced Dock Layout</CardTitle>
            </CardHeader>
            <CardBody>
                <CardText>
                    Advanced layouts can define the initial split and tab tree explicitly.
                </CardText>
            </CardBody>
            <CardBody>
                <DockLayout @bind-State="@advancedDockState" Height="Height.Rem( 24 )" Border="Border.Is1.Rounded">
                    <DockSplit Orientation="DockSplitOrientation.Horizontal" Ratio="0.2">
                        <DockPanel Name="advanced-explorer" Caption="Explorer">
                            <DockPanelHeader>
                                <Strong>Explorer</Strong>
                            </DockPanelHeader>
                            <DockPanelBody>
                                <ListGroup Flush>
                                    <ListGroupItem>Pages</ListGroupItem>
                                    <ListGroupItem>Components</ListGroupItem>
                                    <ListGroupItem>Assets</ListGroupItem>
                                </ListGroup>
                            </DockPanelBody>
                        </DockPanel>
                        <DockSplit Orientation="DockSplitOrientation.Horizontal" Ratio="0.75">
                            <DockContent Padding="Padding.Is4" Background="Background.Light">
                                <Card>
                                    <CardHeader>
                                        <CardTitle>Editor</CardTitle>
                                    </CardHeader>
                                    <CardBody>
                                        Advanced mode starts from a tree instead of side buckets.
                                    </CardBody>
                                </Card>
                            </DockContent>
                            <DockTabs ActivePanel="advanced-properties">
                                <DockPanel Name="advanced-properties" Caption="Properties">
                                    <DockPanelHeader>
                                        <Strong>Properties</Strong>
                                    </DockPanelHeader>
                                    <DockPanelBody>
                                        <Field>
                                            <FieldLabel>Title</FieldLabel>
                                            <TextInput Value="Advanced editor" />
                                        </Field>
                                    </DockPanelBody>
                                </DockPanel>
                                <DockPanel Name="advanced-output" Caption="Output">
                                    <DockPanelHeader>
                                        <Strong>Output</Strong>
                                    </DockPanelHeader>
                                    <DockPanelBody>
                                        Build output and diagnostics.
                                    </DockPanelBody>
                                </DockPanel>
                            </DockTabs>
                        </DockSplit>
                    </DockSplit>
                </DockLayout>
            </CardBody>
        </Card>
    </Column>
</Row>

@code {
    private DockLayoutState dockState = new();

    private DockLayoutState advancedDockState = new();
}