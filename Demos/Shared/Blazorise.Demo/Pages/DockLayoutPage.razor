@page "/tests/utilities/dock-layout"

<Row>
    <Column>
        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>Dock Layout</CardTitle>
            </CardHeader>
            <CardBody>
                <CardText>
                    Dock panes can be resized, moved by dragging their headers, and grouped as tabs when multiple panes share the same dock position.
                </CardText>
            </CardBody>
            <CardBody>
                <DockLayout @bind-State="@dockState" Height="Height.Rem( 34 )" Border="Border.Is1.Rounded">
                    <DockPane Name="explorer" Caption="Explorer" DockRole="DockRole.Tool" Dock="DockPanePosition.Left" Size="16rem" MinSize="2rem" Resizable>
                        <DockPaneHeader>
                            <Strong>Explorer</Strong>
                        </DockPaneHeader>
                        <DockPaneBody>
                            <ListGroup Flush>
                                <ListGroupItem>Documents</ListGroupItem>
                                <ListGroupItem>Reports</ListGroupItem>
                                <ListGroupItem>Templates</ListGroupItem>
                                <ListGroupItem>Data Sources</ListGroupItem>
                            </ListGroup>
                        </DockPaneBody>
                    </DockPane>

                    <DockPane Name="toolbar" Caption="Toolbar" DockRole="DockRole.Tool" Dock="DockPanePosition.Top" Movable="false">
                        <DockPaneBody Padding="Padding.Is2">
                            <Div Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2">
                                <Button Color="Color.Primary" Size="Size.Small">
                                    <Icon Name="IconName.Save" />
                                    Save
                                </Button>
                                <Button Color="Color.Light" Size="Size.Small">
                                    <Icon Name="IconName.Sync" />
                                    Refresh
                                </Button>
                                <Button Color="Color.Light" Size="Size.Small">
                                    <Icon Name="IconName.Search" />
                                    Find
                                </Button>
                            </Div>
                        </DockPaneBody>
                    </DockPane>

                    <DockPane Name="designer" Caption="Designer" DockRole="DockRole.Document" ShowTab="false">
                        <DockPaneBody Padding="Padding.Is4" Background="Background.Light">
                            <Card>
                                <CardHeader>
                                    <CardTitle>Design Surface</CardTitle>
                                </CardHeader>
                                <CardBody>
                                    <Paragraph>
                                        The center document pane can hide its tab, while tool panes can still be dropped into the center document group.
                                    </Paragraph>
                                    <Alert Color="Color.Info" Visible>
                                        Drag pane headers to another edge of the layout. Drop a pane onto the center to create a document tab group.
                                    </Alert>
                                </CardBody>
                            </Card>
                        </DockPaneBody>
                    </DockPane>

                    <DockPane Name="properties" Caption="Properties" DockRole="DockRole.Tool" Dock="DockPanePosition.Right" Size="18rem" MinSize="2rem" Resizable>
                        <DockPaneHeader>
                            <Strong>Properties</Strong>
                        </DockPaneHeader>
                        <DockPaneBody>
                            <Field>
                                <FieldLabel>Name</FieldLabel>
                                <TextInput Value="Invoice summary" />
                            </Field>
                            <Field>
                                <FieldLabel>Mode</FieldLabel>
                                <Select TValue="string" Value="@("Design")">
                                    <SelectItem Value="@("Design")">Design</SelectItem>
                                    <SelectItem Value="@("Preview")">Preview</SelectItem>
                                </Select>
                            </Field>
                        </DockPaneBody>
                        <DockPaneFooter>
                            <Button Color="Color.Primary" Size="Size.Small">Apply</Button>
                        </DockPaneFooter>
                    </DockPane>

                    <DockPane Name="report-explorer" Caption="Report Explorer" DockRole="DockRole.Tool" Dock="DockPanePosition.Right" Size="18rem" MinSize="2rem" Resizable>
                        <DockPaneHeader>
                            <Strong>Report Explorer</Strong>
                        </DockPaneHeader>
                        <DockPaneBody>
                            <ListGroup Flush>
                                <ListGroupItem>Invoice report</ListGroupItem>
                                <ListGroupItem>Report header</ListGroupItem>
                                <ListGroupItem>Page header</ListGroupItem>
                                <ListGroupItem>Detail</ListGroupItem>
                                <ListGroupItem>Report footer</ListGroupItem>
                            </ListGroup>
                        </DockPaneBody>
                    </DockPane>

                    <DockPane Name="output" Caption="Output" DockRole="DockRole.Tool" Dock="DockPanePosition.Bottom" Size="6rem" Resizable>
                        <DockPaneHeader>
                            <Strong>Output</Strong>
                        </DockPaneHeader>
                        <DockPaneBody>
                            Ready. No errors or warnings.
                        </DockPaneBody>
                    </DockPane>
                </DockLayout>
            </CardBody>
        </Card>
    </Column>
</Row>

@code {
    private DockLayoutState dockState = new();
}