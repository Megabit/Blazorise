        "Blazorise.SignaturePad.wasm",
        "Blazorise.SpinKit.wasm",
        "Blazorise.Splitter.wasm",
        "Blazorise.TreeView.wasm",
        "Blazorise.Video.wasm",
    ];

    private static readonly string[] componentRoutes =
    [
        "tests/autocomplete",
        "tests/dropdownlist",
        "tests/listview",
        "tests/onetimeinput",
        "tests/passwordstrength",
        "tests/repeater",
        "tests/selectlist",
        "tests/transferlist",
    ];

    private static readonly string[] extensionRoutes =
    [
        "tests/animate",
        "tests/barcode",
        "tests/captcha",
        "tests/cropper",
        "tests/gantt",
        "tests/loadingindicator",
        "tests/lottie-animation",
        "tests/maps",
        "tests/markdown",
        "tests/pdfviewer",
        "tests/pivotgrid",
        "tests/qrcode",
        "tests/reporting",
        "tests/richtextedit",
        "tests/scheduler",
        "tests/signaturepad",
        "tests/snackbar",
        "tests/spinkit",
        "tests/splitter",
        "tests/treeview",
        "tests/video",
    ];

    private static readonly Dictionary<string, string[]> routeAssemblyDependencies = new( StringComparer.OrdinalIgnoreCase )
    {
        ["tests/gestures"] = animateAssemblies,
    };

    private readonly List<Assembly> lazyAssemblies = [];

    private readonly HashSet<string> loadedAssemblyFiles = new( StringComparer.OrdinalIgnoreCase );

    private async Task OnNavigateAsync( NavigationContext context )
    {
        var assembliesToLoad = GetAssemblyFilesForRoute( context.Path )
            .Where( assemblyFile => !loadedAssemblyFiles.Contains( assemblyFile ) )
            .ToArray();

        if ( assembliesToLoad.Length == 0 )
            return;

        try
        {
            context.CancellationToken.ThrowIfCancellationRequested();

            var loadedAssemblies = await AssemblyLoader.LoadAssembliesAsync( assembliesToLoad );

            context.CancellationToken.ThrowIfCancellationRequested();

            foreach ( var assembly in loadedAssemblies )
            {
                if ( !lazyAssemblies.Any( x => x.FullName == assembly.FullName ) )
                {
                    lazyAssemblies.Add( assembly );
                }
            }

            foreach ( var assemblyFile in assembliesToLoad )
            {
                loadedAssemblyFiles.Add( assemblyFile );
            }
        }
        catch ( OperationCanceledException )
        {
            throw;
        }
        catch ( Exception exception )
        {
            Logger.LogError( exception, "Unable to lazy load demo assemblies for route '{Route}'.", context.Path );
        }
    }

    private static IEnumerable<string> GetAssemblyFilesForRoute( string path )
    {
        path = path?.TrimStart( '/' ) ?? string.Empty;

        if ( path.StartsWith( "tests/charts", StringComparison.OrdinalIgnoreCase ) )
            return chartAssemblies;

        if ( path.StartsWith( "tests/datagrid", StringComparison.OrdinalIgnoreCase ) )
            return dataGridAssemblies;

        if ( IsInRouteGroup( path, componentRoutes ) )
            return componentAssemblies;

        if ( routeAssemblyDependencies.TryGetValue( path, out string[] routeAssemblies ) )
            return routeAssemblies;

        if ( IsInRouteGroup( path, extensionRoutes ) )
            return extensionAssemblies;

        return [];
    }

    private static bool IsInRouteGroup( string path, IEnumerable<string> routes )
    {
        return routes.Any( route => string.Equals( path, route, StringComparison.OrdinalIgnoreCase ) );
    }

