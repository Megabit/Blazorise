    ];

    private static readonly string[] componentAssemblies =
    [
        "Blazorise.Demo.Components.wasm",
    ];

    private static readonly string[] animateAssemblies =
    [
        "Blazorise.Animate.wasm",
    ];

    private static readonly string[] extensionAssemblies =
    [
        "Blazorise.Demo.Extensions.wasm",
        "Blazorise.Animate.wasm",
        "Blazorise.Barcode.wasm",
        "Blazorise.Cropper.wasm",
