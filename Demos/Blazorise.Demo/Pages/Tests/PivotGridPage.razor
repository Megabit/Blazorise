@page "/tests/pivotgrid"

<Row>
    <Column>
        <Card Margin="Margin.Is4.OnY">
            <CardHeader>
                <CardTitle>PivotGrid</CardTitle>
            </CardHeader>
            <CardBody>
                <Row>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@expandableRows">Expandable rows</Switch>
                        </Field>
                    </Column>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@showRowSubtotals">Row subtotals</Switch>
                        </Field>
                    </Column>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@showRowTotals">Row totals</Switch>
                        </Field>
                    </Column>                   
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@pageByGroups">Page by groups</Switch>
                        </Field>
                    </Column>
                </Row>

                <Row>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@expandableColumns">Expandable columns</Switch>
                        </Field>
                    </Column>                    
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@showColumnSubtotals">Column subtotals</Switch>
                        </Field>
                    </Column>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@showColumnTotals">Column totals</Switch>
                        </Field>
                    </Column>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnTablet.Is3.OnDesktop">
                        <Field>
                            <Switch @bind-Value="@initiallyExpanded">Initially expanded</Switch>
                        </Field>
                    </Column>
                </Row>

                <Row>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is4.OnDesktop">
                        <Field>
                            <FieldLabel>Row total position</FieldLabel>
                            <FieldBody>
                                <Select TValue="PivotGridTotalPosition" @bind-Value="@rowTotalPosition" Disabled="@expandableRows">
                                    <SelectItem TValue="PivotGridTotalPosition" Value="PivotGridTotalPosition.Before">Before</SelectItem>
                                    <SelectItem TValue="PivotGridTotalPosition" Value="PivotGridTotalPosition.After">After</SelectItem>
                                </Select>
                            </FieldBody>
                        </Field>
                    </Column>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is4.OnDesktop">
                        <Field>
                            <FieldLabel>Column total position</FieldLabel>
                            <FieldBody>
                                <Select TValue="PivotGridTotalPosition" @bind-Value="@columnTotalPosition" Disabled="@expandableColumns">
                                    <SelectItem TValue="PivotGridTotalPosition" Value="PivotGridTotalPosition.Before">Before</SelectItem>
                                    <SelectItem TValue="PivotGridTotalPosition" Value="PivotGridTotalPosition.After">After</SelectItem>
                                </Select>
                            </FieldBody>
                        </Field>
                    </Column>
                    <Column ColumnSize="ColumnSize.Is12.OnMobile.Is4.OnDesktop">
                        <Field>
                            <FieldLabel>Data source</FieldLabel>
                            <FieldBody>
                                <Select TValue="PivotGridDemoDataMode" @bind-Value="@dataMode">
                                    <SelectItem TValue="PivotGridDemoDataMode" Value="PivotGridDemoDataMode.Data">Data</SelectItem>
                                    <SelectItem TValue="PivotGridDemoDataMode" Value="PivotGridDemoDataMode.ReadData">ReadData</SelectItem>
                                    <SelectItem TValue="PivotGridDemoDataMode" Value="PivotGridDemoDataMode.DataSource">DataSource</SelectItem>
                                </Select>
                            </FieldBody>
                        </Field>
                    </Column>
                </Row>

                <PivotGrid TItem="PivotModel"
                           Data="@CurrentData"
                           ReadData="@CurrentReadData"
                           DataSource="@CurrentDataSource"
                           ShowPager
                           ShowPageSizes
                           ShowFieldChooser
                           ExpandableRows="@expandableRows"
                           ExpandableColumns="@expandableColumns"
                           InitiallyExpanded="@initiallyExpanded"
                           PageByGroups="@pageByGroups"
                           ShowRowSubtotals="@showRowSubtotals"
                           ShowColumnSubtotals="@showColumnSubtotals"
                           ShowRowTotals="@showRowTotals"
                           ShowColumnTotals="@showColumnTotals"
                           RowTotalPosition="@rowTotalPosition"
                           ColumnTotalPosition="@columnTotalPosition"
                           PageSize="5"
                           Striped
                           Hoverable>
                    <PivotGridFields>
                        <PivotGridField Field="@nameof( PivotModel.Region )" Caption="Region" />
                        <PivotGridField Field="@nameof( PivotModel.City )" Caption="City" />
                        <PivotGridField Field="@nameof( PivotModel.Category )" Caption="Category" />
                        <PivotGridField Field="@nameof( PivotModel.Product )" Caption="Product" />
                        <PivotGridField Field="@nameof( PivotModel.ContractValue )" Caption="Contract value" />
                        <PivotGridField Field="@nameof( PivotModel.Units )" Caption="Units" />
                    </PivotGridFields>
                    <PivotGridColumns>
                        <PivotGridColumn Field="@nameof( PivotModel.Region )" Caption="Region" />
                        <PivotGridColumn Field="@nameof( PivotModel.City )" Caption="City" />
                    </PivotGridColumns>
                    <PivotGridRows>
                        <PivotGridRow Field="@nameof( PivotModel.Category )" Caption="Category" />
                        <PivotGridRow Field="@nameof( PivotModel.Product )" Caption="Product" />
                    </PivotGridRows>
                    <PivotGridAggregates>
                        <PivotGridAggregate Field="@nameof( PivotModel.ContractValue )"
                                            Caption="Contract value"
                                            DisplayFormat="{0:C}"
                                            DisplayFormatProvider="@System.Globalization.CultureInfo.GetCultureInfo( "fr-FR" )" />
                        <PivotGridAggregate Field="@nameof( PivotModel.Units )"
                                            Caption="Units"
                                            AggregateFunction="PivotGridAggregateFunction.Sum" />
                    </PivotGridAggregates>
                </PivotGrid>
            </CardBody>
        </Card>
    </Column>
</Row>

@code {
    private bool expandableRows = true;

    private bool expandableColumns;

    private bool initiallyExpanded = true;

    private bool pageByGroups = false;

    private bool showRowSubtotals = true;

    private bool showColumnSubtotals = false;

    private bool showRowTotals = true;

    private bool showColumnTotals = true;

    private PivotGridTotalPosition rowTotalPosition = PivotGridTotalPosition.After;

    private PivotGridTotalPosition columnTotalPosition = PivotGridTotalPosition.After;

    private PivotGridDemoDataMode dataMode;

    private IPivotGridDataSource<PivotModel> contractsDataSource;

    private readonly List<PivotModel> contracts =
    [
        new() { Region = "Western", City = "London", Category = "Hardware", Product = "Laptops", ContractValue = 127500m, Units = 34 },
        new() { Region = "Western", City = "London", Category = "Hardware", Product = "Monitors", ContractValue = 43800m, Units = 96 },
        new() { Region = "Western", City = "London", Category = "Software", Product = "Licenses", ContractValue = 89200m, Units = 240 },
        new() { Region = "Western", City = "Paris", Category = "Hardware", Product = "Laptops", ContractValue = 98400m, Units = 28 },
        new() { Region = "Western", City = "Paris", Category = "Software", Product = "Licenses", ContractValue = 116300m, Units = 310 },
        new() { Region = "Western", City = "Paris", Category = "Services", Product = "Consulting", ContractValue = 75400m, Units = 42 },
        new() { Region = "Central", City = "Berlin", Category = "Hardware", Product = "Monitors", ContractValue = 51200m, Units = 118 },
        new() { Region = "Central", City = "Berlin", Category = "Services", Product = "Consulting", ContractValue = 104900m, Units = 58 },
        new() { Region = "Central", City = "Berlin", Category = "Software", Product = "Support", ContractValue = 39600m, Units = 120 },
        new() { Region = "Central", City = "Madrid", Category = "Hardware", Product = "Laptops", ContractValue = 68200m, Units = 19 },
        new() { Region = "Central", City = "Madrid", Category = "Services", Product = "Training", ContractValue = 28700m, Units = 64 },
        new() { Region = "Central", City = "Madrid", Category = "Software", Product = "Support", ContractValue = 45100m, Units = 135 },
    ];

    protected override void OnInitialized()
    {
        contractsDataSource = new DemoPivotGridDataSource( contracts );
    }

    private IEnumerable<PivotModel> CurrentData
        => dataMode == PivotGridDemoDataMode.Data ? contracts : null;

    private EventCallback<PivotGridReadDataEventArgs<PivotModel>> CurrentReadData
        => dataMode == PivotGridDemoDataMode.ReadData
            ? EventCallback.Factory.Create<PivotGridReadDataEventArgs<PivotModel>>( this, ReadPivotData )
            : default;

    private IPivotGridDataSource<PivotModel> CurrentDataSource
        => dataMode == PivotGridDemoDataMode.DataSource ? contractsDataSource : null;

    private Task ReadPivotData( PivotGridReadDataEventArgs<PivotModel> eventArgs )
    {
        eventArgs.Data = contracts;
        eventArgs.TotalItems = contracts.Count;

        return Task.CompletedTask;
    }

    private enum PivotGridDemoDataMode
    {
        Data,
        ReadData,
        DataSource,
    }

    private sealed class DemoPivotGridDataSource : IPivotGridDataSource<PivotModel>
    {
        private readonly IReadOnlyList<PivotModel> data;

        public DemoPivotGridDataSource( IReadOnlyList<PivotModel> data )
        {
            this.data = data;
        }

        public Task<PivotGridDataResult<PivotModel>> ReadDataAsync( PivotGridDataRequest request, System.Threading.CancellationToken cancellationToken )
            => Task.FromResult( new PivotGridDataResult<PivotModel>
            {
                Data = data,
                TotalItems = data.Count,
            } );
    }

    public class PivotModel
    {
        public string Region { get; set; }

        public string City { get; set; }

        public string Category { get; set; }

        public string Product { get; set; }

        public decimal ContractValue { get; set; }

        public int Units { get; set; }
    }
}