                    <UnorderedListItem><Code>Flex="Flex.{Grow|Shrink}.Is1.OnQuadHD"</Code></UnorderedListItem>
                </UnorderedList>
            </CardBody>
        </Card>
    </Column>
</Row>

<Row>
