            </CardBody>
            <CardBody>
                <Div Flex="Flex._" Display="Display.Flex" Margin="Margin.Is3.FromBottom" Style="@flexContainerStyle">
                    <Div Flex="Flex.Fill" Padding="Padding.Is2" Style="@flexItemStyle">
                        Flex item with a lot of content
                    </Div>
                    <Div Flex="Flex.Fill" Padding="Padding.Is2" Style="@flexItemStyle">
                        Flex item
                    </Div>
                    <Div Flex="Flex.Fill" Padding="Padding.Is2" Style="@flexItemStyle">
                        Flex item
                    </Div>
                </Div>
            </CardBody>
