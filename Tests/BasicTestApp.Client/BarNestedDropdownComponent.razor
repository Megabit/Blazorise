<Bar Mode="BarMode.VerticalSmall"
     Visible>
    <BarMenu>
        <BarStart>
            <BarItem>
                <BarDropdown>
                    <BarDropdownToggle ElementId="parent-toggle">
                        Parent
                    </BarDropdownToggle>
                    <BarDropdownMenu ElementId="parent-menu">
                        <BarDropdownItem ElementId="parent-item">
                            Parent item
                        </BarDropdownItem>
                        <BarDropdown>
                            <BarDropdownToggle ElementId="child-toggle">
                                Child
                            </BarDropdownToggle>
                            <BarDropdownMenu ElementId="child-menu">
                                <BarDropdownItem ElementId="child-item">
                                    Child item
                                </BarDropdownItem>
                            </BarDropdownMenu>
                        </BarDropdown>
                        <BarDropdownItem ElementId="parent-sibling-item">
                            Parent sibling
                        </BarDropdownItem>
                    </BarDropdownMenu>
                </BarDropdown>
            </BarItem>
        </BarStart>
    </BarMenu>
</Bar>