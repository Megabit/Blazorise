        </DocsPageUnorderedListItem>
        <DocsPageUnorderedListItem>
            For <Strong>Server</Strong>, update <Strong>_Layout.cshtml</Strong> or <Strong>_Host.cshtml</Strong>.
        </DocsPageUnorderedListItem>
        <DocsPageUnorderedListItem>
            For <Strong>.NET 8</Strong>, update <Strong>App.razor</Strong>.
        </DocsPageUnorderedListItem>
    </DocsPageUnorderedList>
</DocsPageParagraph>

