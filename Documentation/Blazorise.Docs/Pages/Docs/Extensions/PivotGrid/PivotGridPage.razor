    <DocsPageSectionContent Code="PivotGridTemplatesEventsExample" Outlined FullWidth>
        <PivotGridTemplatesEventsExample />
    </DocsPageSectionContent>
</DocsPageSection>

<DocsPageSection>
    <DocsPageSectionHeader Title="Filters and Expansion">
        <Paragraph>
            Use the field chooser to move fields into filters, and enable expandable rows or columns when users should drill into grouped results.
        </Paragraph>
        <Paragraph>
            Expandable grouped rows and columns render section headers independently from subtotal display, so users can still expand or collapse groups when subtotals are hidden.
        </Paragraph>
    </DocsPageSectionHeader>
    <DocsPageSectionContent Code="PivotGridFiltersExpansionExample" Outlined FullWidth>
        <PivotGridFiltersExpansionExample />
    </DocsPageSectionContent>
</DocsPageSection>

<DocsPageSection>
    <DocsPageSectionHeader Title="Custom Aggregator">
        Set <Code>Aggregator</Code> when a value field needs domain-specific aggregation instead of one of the built-in aggregate functions.
