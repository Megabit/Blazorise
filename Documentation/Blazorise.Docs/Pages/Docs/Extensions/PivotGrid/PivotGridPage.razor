</DocsPageSection>

<DocsPageSection>
    <DocsPageSectionHeader Title="Styling">
        Use <Code>CellStyling</Code>, <Code>RowHeaderStyling</Code>, and <Code>ColumnHeaderStyling</Code> to apply conditional styling.
    </DocsPageSectionHeader>
    <DocsPageSectionContent Code="PivotGridStylingExample" Outlined FullWidth>
        <PivotGridStylingExample />
    </DocsPageSectionContent>
</DocsPageSection>

