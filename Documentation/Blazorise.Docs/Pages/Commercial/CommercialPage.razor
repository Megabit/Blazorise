@page "/commercial"

<Seo Canonical="/commercial" Title="Blazorise Commercial" Description="Commercial Blazorise plans provide licensing coverage, premium support, onboarding, and expert services for teams building production Blazor applications." />

<PageHeader>
    <Title>
        Commercial Blazor UI for teams shipping real products
    </Title>
    <Subtitle>
        Licensing, support, services, and expert guidance for production Blazor applications.
    </Subtitle>
    <Description>
        Blazorise Commercial helps teams standardize UI delivery, reduce framework risk, and get direct help from the people building the component library. Use it when your product needs reliable support, long-term maintainability, and a clear commercial license.
    </Description>
    <Actions>
        <Button Type="ButtonType.Link" To="pricing" Color="Color.Primary" Size="Size.Large" Padding="Padding.Is4.OnX.Is3.FromEnd.OnTablet">
            <Icon Name="IconName.Key" />
            View Pricing
        </Button>
        <Button Type="ButtonType.Link" To="book-a-demo" Color="Color.Secondary" Size="Size.Large" Padding="Padding.Is4.OnX">
            <Icon Name="IconName.Microphone" />
            Book a Demo
        </Button>
    </Actions>
</PageHeader>

<Container Padding="Padding.Is5.OnY">
    <Row>
        @foreach ( var item in CommercialHighlights )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is4.OnDesktop" Margin="Margin.Is3.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Icon Name="@item.Icon" IconSize="IconSize.x2" TextColor="@item.TextColor" Margin="Margin.Is3.FromBottom" />
                        <Heading Size="HeadingSize.Is4" TextWeight="TextWeight.SemiBold">@item.Title</Heading>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">@item.Description</Paragraph>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row>
        <Column Margin="Margin.IsAuto.OnX">
            <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold" TextAlignment="TextAlignment.Center">
                Trusted by teams building serious Blazor products
            </Heading>
            <Lead TextColor="TextColor.Muted" TextAlignment="TextAlignment.Center">
                Product teams use Blazorise to standardize UI delivery across internal tools, SaaS platforms, customer portals, and line-of-business applications.
            </Lead>
        </Column>
    </Row>
    <HomeClientLogos />
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row Flex="Flex.AlignItems.Center">
        <Column ColumnSize="ColumnSize.Is12.Is5.OnDesktop" Margin="Margin.Is4.FromBottom.OnMobile">
            <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                What commercial teams get
            </Heading>
            <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted">
                Commercial plans are designed for organizations that need more than package access. They combine license coverage with direct support, predictable escalation, and hands-on guidance when delivery depends on the UI layer.
            </Paragraph>
            <Button Type="ButtonType.Link" To="pricing" Color="Color.Primary" Size="Size.Large">
                Compare Plans
            </Button>
        </Column>
        <Column ColumnSize="ColumnSize.Is12.Is7.OnDesktop">
            <Row>
                @foreach ( var item in CommercialBenefits )
                {
                    <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet" Margin="Margin.Is3.FromBottom">
                        <Div Flex="Flex.AlignItems.Start" Gap="Gap.Is3">
                            <Icon Name="IconName.Check" TextColor="TextColor.Success" Margin="Margin.Is1.FromTop" />
                            <Div>
                                <Strong>@item.Title</Strong>
                                <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is1.FromTop.Is0.FromBottom">@item.Description</Paragraph>
                            </Div>
                        </Div>
                    </Column>
                }
            </Row>
        </Column>
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Div TextAlignment="TextAlignment.Center" Margin="Margin.Is4.FromBottom">
        <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
            Plan the business case
        </Heading>
        <Lead TextColor="TextColor.Muted">
            Use these paths when your team needs to justify licensing cost or needs delivery help beyond support.
        </Lead>
    </Div>

    <Row>
        @foreach ( var item in DecisionPaths )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnDesktop" Margin="Margin.Is4.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody Padding="Padding.Is5" Flex="Flex.Column" Gap="Gap.Is3">
                        <Icon Name="@item.Icon" IconSize="IconSize.x2" TextColor="@item.TextColor" />
                        <Heading Size="HeadingSize.Is3" TextWeight="TextWeight.SemiBold" Margin="Margin.Is0">
                            @item.Title
                        </Heading>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0">
                            @item.Description
                        </Paragraph>
                        <Div Margin="Margin.IsAuto.FromTop">
                            <Button Type="ButtonType.Link" To="@item.To" Color="@item.Color" Size="Size.Large">
                                @item.ButtonText
                            </Button>
                        </Div>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Div TextAlignment="TextAlignment.Center" Margin="Margin.Is4.FromBottom">
        <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
            Services for teams that need a stronger delivery path
        </Heading>
        <Lead TextColor="TextColor.Muted">
            Use the Blazorise team for integration planning, migration work, onboarding, and production support.
        </Lead>
    </Div>

    <Row>
        @foreach ( var item in ServiceCards )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet.Is4.OnDesktop" Margin="Margin.Is4.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Icon Name="@item.Icon" IconSize="IconSize.x2" TextColor="TextColor.Primary" Margin="Margin.Is3.FromBottom" />
                        <Heading Size="HeadingSize.Is4" TextWeight="TextWeight.SemiBold">@item.Title</Heading>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">@item.Description</Paragraph>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>

    <Div TextAlignment="TextAlignment.Center" Margin="Margin.Is3.FromTop">
        <Button Type="ButtonType.Link" To="contact" Color="Color.Primary" Size="Size.Large">
            Talk to Us
        </Button>
    </Div>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Card Border="Border.Rounded" Shadow="Shadow.Small">
        <CardBody Padding="Padding.Is5">
            <Row Flex="Flex.AlignItems.Center">
                <Column ColumnSize="ColumnSize.Is12.Is7.OnDesktop">
                    <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                        Need help deciding what fits?
                    </Heading>
                    <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">
                        Share your team size, project scope, and support expectations. We can help map the right license, support path, and optional services.
                    </Paragraph>
                </Column>
                <Column ColumnSize="ColumnSize.Is12.Is5.OnDesktop" TextAlignment="TextAlignment.End" Margin="Margin.Is4.FromTop.OnMobile">
                    <Button Type="ButtonType.Link" To="book-a-demo" Color="Color.Primary" Size="Size.Large" Margin="Margin.Is2.FromEnd">
                        Book a Demo
                    </Button>
                    <Button Type="ButtonType.Link" To="pricing" Color="Color.Light" Size="Size.Large">
                        View Plans
                    </Button>
                </Column>
            </Row>
        </CardBody>
    </Card>
</Container>

@code {
    private static readonly CommercialHighlight[] CommercialHighlights =
    [
        new( IconName.Key, TextColor.Primary, "License clarity", "Commercial use coverage for organizations, teams, and customer-facing products." ),
        new( IconName.Users, TextColor.Info, "Priority support", "Get direct assistance from Blazorise maintainers when implementation questions block delivery." ),
        new( IconName.Building, TextColor.Secondary, "Enterprise fit", "Support for design systems, migrations, onboarding, and product-specific delivery needs." )
    ];

    private static readonly CommercialBenefit[] CommercialBenefits =
    [
        new( "Production confidence", "Resolve UI issues with a supported component vendor behind your application." ),
        new( "Faster delivery", "Use ready-made components and fluent utilities instead of building a private UI kit from scratch." ),
        new( "Direct escalation", "Move critical questions beyond community channels when timelines matter." ),
        new( "Long-term maintainability", "Standardize on a consistent component model across teams and products." )
    ];

    private static readonly DecisionPath[] DecisionPaths =
    [
        new( IconName.ChartLine, TextColor.Primary, "Estimate ROI", "Compare internal build effort, ownership cost, license spend, savings, and time-to-market impact before asking for budget approval.", "roi-calculator", "Open ROI Calculator", Color.Primary ),
        new( IconName.Briefcase, TextColor.Secondary, "Need custom work?", "Use Feature Sponsorship, Custom Development, or the Priority Development Queue when licensing and support are not enough to meet your delivery schedule.", "custom-work", "View Custom Work", Color.Secondary )
    ];

    private static readonly ServiceCard[] ServiceCards =
    [
        new( IconName.Building, "Design System Integration", "Adapt Blazorise to your existing brand, token system, and product UI conventions." ),
        new( IconName.Sync, "Project Migration", "Move legacy interfaces or non-Blazor frontends into a modern Blazor architecture." ),
        new( IconName.Code, "Custom Development", "Add specialized components, pages, and workflows with help from Blazorise experts." ),
        new( IconName.Users, "Live Remote Support", "Work directly with the team on implementation details, debugging, and delivery risks." ),
        new( IconName.Book, "Training", "Give your team practical Blazorise and Blazor guidance through hands-on sessions." ),
        new( IconName.Check, "Onboarding", "Set up project structure, provider configuration, CI/CD expectations, and rollout practices." )
    ];

    private sealed record CommercialHighlight( IconName Icon, TextColor TextColor, string Title, string Description );

    private sealed record CommercialBenefit( string Title, string Description );

    private sealed record DecisionPath( IconName Icon, TextColor TextColor, string Title, string Description, string To, string ButtonText, Color Color );

    private sealed record ServiceCard( IconName Icon, string Title, string Description );
}