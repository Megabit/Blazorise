@page "/about"
@inherits BasePage

<Seo Canonical="/about" Title="About Blazorise" Description="Learn about Blazorise, the source-available Blazor UI component library built by Megabit, including mission, company details, and commercial contact information." />

<PageHeader>
    <Title>
        About <Span Class="gradient-commercial">Blazorise</Span>
    </Title>
    <Subtitle>
        A source-available Blazor UI platform built and maintained by Megabit.
    </Subtitle>
    <Description>
        We build Blazorise so .NET teams can ship polished, maintainable applications without rebuilding the same UI foundation in every product. The library combines production-ready components, provider flexibility, fluent utilities, documentation, and commercial support.
    </Description>
    <Actions>
        <Button Type="ButtonType.Link" To="contact" Color="Color.Primary" Size="Size.Large" Padding="Padding.Is4.OnX.Is3.FromEnd.OnTablet">
            <Icon Name="IconName.Comment" />
            Contact Us
        </Button>
        <Button Type="ButtonType.Link" To="https://github.com/megabit" Target="Target.Blank" Color="Color.Secondary" Size="Size.Large" Padding="Padding.Is4.OnX">
            <Icon Name="@("fab fa-github")" />
            GitHub
        </Button>
    </Actions>
</PageHeader>

<Container Padding="Padding.Is5.OnY">
    <Row>
        @foreach ( AboutStat item in AboutStats )
        {
            <Column @key="@item.Label" ColumnSize="ColumnSize.Is12.Is4.OnDesktop" Margin="Margin.Is3.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Paragraph TextSize="TextSize.Heading2" TextWeight="TextWeight.Bold" Margin="Margin.Is0.FromBottom">@item.Value</Paragraph>
                        <Paragraph TextWeight="TextWeight.SemiBold" Margin="Margin.Is1.FromBottom">@item.Label</Paragraph>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">@item.Description</Paragraph>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row Flex="Flex.AlignItems.Center">
        <Column ColumnSize="ColumnSize.Is12.Is6.OnDesktop" Margin="Margin.Is4.FromBottom.OnMobile">
            <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                Built by a focused product team in Croatia
            </Heading>
            <Lead TextColor="TextColor.Muted">
                Megabit d.o.o. develops and maintains Blazorise, the component library behind the documentation, demos, commercial plans, and support services.
            </Lead>
            <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted">
                Blazorise is designed for teams that want productive Blazor development without being locked into one CSS framework. It renders provider-specific markup while keeping the component model familiar across Bootstrap, Tailwind, Fluent 2, Bulma, Material, Ant Design, and more.
            </Paragraph>
            <Div Flex="Flex.Column.Row.OnTablet" Gap="Gap.Is3" Margin="Margin.Is4.FromTop">
                <Button Type="ButtonType.Link" To="features" Color="Color.Primary">
                    Explore Features
                </Button>
                <Button Type="ButtonType.Link" To="commercial" Color="Color.Light">
                    Commercial Options
                </Button>
            </Div>
        </Column>

        <Column ColumnSize="ColumnSize.Is12.Is6.OnDesktop">
            <Card Border="Border.Rounded" Shadow="Shadow.Small">
                <CardBody>
                    <Heading Size="HeadingSize.Is3" TextWeight="TextWeight.Bold" Margin="Margin.Is3.FromBottom">
                        Company Details
                    </Heading>
                    <Table Responsive Borderless>
                        <TableBody>
                            @foreach ( CompanyFact item in CompanyFacts )
                            {
                                <TableRow @key="@item.Label">
                                    <TableRowHeader TextAlignment="TextAlignment.Start">@item.Label</TableRowHeader>
                                    <TableRowCell TextAlignment="TextAlignment.End">@item.Value</TableRowCell>
                                </TableRow>
                            }
                            <TableRow>
                                <TableRowHeader TextAlignment="TextAlignment.Start">Website</TableRowHeader>
                                <TableRowCell TextAlignment="TextAlignment.End">
                                    <Anchor To="https://megabitsoft.com/" Target="Target.Blank">megabitsoft.com</Anchor>
                                </TableRowCell>
                            </TableRow>
                            <TableRow>
                                <TableRowHeader TextAlignment="TextAlignment.Start">Contact</TableRowHeader>
                                <TableRowCell TextAlignment="TextAlignment.End">
                                    <Anchor To="@($"mailto:{MailToLink}")">@MailToAddress</Anchor>
                                </TableRowCell>
                            </TableRow>
                        </TableBody>
                    </Table>
                </CardBody>
            </Card>
        </Column>
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Div TextAlignment="TextAlignment.Center" Margin="Margin.Is4.FromBottom">
        <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
            What guides the work
        </Heading>
        <Lead TextColor="TextColor.Muted">
            Blazorise is shaped around practical product development, provider flexibility, and long-term maintainability.
        </Lead>
    </Div>

    <Row>
        @foreach ( AboutPrinciple item in AboutPrinciples )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet.Is4.OnDesktop" Margin="Margin.Is4.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Icon Name="@item.Icon" IconSize="IconSize.x2" TextColor="@item.TextColor" Margin="Margin.Is3.FromBottom" />
                        <Heading Size="HeadingSize.Is4" TextWeight="TextWeight.SemiBold">@item.Title</Heading>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">@item.Description</Paragraph>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Card Border="Border.Rounded" Shadow="Shadow.Small">
        <CardBody Padding="Padding.Is5">
            <Row>
                <Column ColumnSize="ColumnSize.Is12.Is5.OnDesktop" Margin="Margin.Is4.FromBottom.OnMobile">
                    <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                        Bank Details
                    </Heading>
                    <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">
                        Official payment information for Megabit d.o.o.
                    </Paragraph>
                </Column>
                <Column ColumnSize="ColumnSize.Is12.Is7.OnDesktop">
                    <Table Responsive Borderless>
                        <TableBody>
                            @foreach ( CompanyFact item in BankFacts )
                            {
                                <TableRow @key="@item.Label">
                                    <TableRowHeader TextAlignment="TextAlignment.Start">@item.Label</TableRowHeader>
                                    <TableRowCell TextAlignment="TextAlignment.End">@item.Value</TableRowCell>
                                </TableRow>
                            }
                        </TableBody>
                    </Table>
                </Column>
            </Row>
        </CardBody>
    </Card>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Card Border="Border.Rounded" Shadow="Shadow.Small">
        <CardBody Padding="Padding.Is5">
            <Row Flex="Flex.AlignItems.Center">
                <Column ColumnSize="ColumnSize.Is12.Is8.OnDesktop">
                    <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                        Want to work with the team behind Blazorise?
                    </Heading>
                    <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">
                        Contact us for licensing, support, services, partnerships, or product questions.
                    </Paragraph>
                </Column>
                <Column ColumnSize="ColumnSize.Is12.Is4.OnDesktop" TextAlignment="TextAlignment.End" Margin="Margin.Is4.FromTop.OnMobile">
                    <Button Type="ButtonType.Link" To="contact" Color="Color.Primary" Size="Size.Large">
                        Contact Us
                    </Button>
                </Column>
            </Row>
        </CardBody>
    </Card>
</Container>

