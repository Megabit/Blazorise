@page "/"

<Seo Canonical="/" Title="Blazorise - Blazor Component Library" Description="Ship accessible, production-ready Blazor apps quickly with 100+ components, consistent theming, and first-class support for Bootstrap, Tailwind, Bulma, AntDesign, Material, Fluent UI, and more." />

<PageHeader>
    <Title>
        We handle the <Span Class="gradient-commercial">UI</Span>. You handle the product.
    </Title>
    <Subtitle>
        Components, providers, utilities, and support for teams that need to ship reliable web applications in C#.
    </Subtitle>
    <Description>
        Blazorise gives you a complete UI foundation for real product work: complex data screens, responsive layouts, validation, theming, commercial support, and provider flexibility across the CSS frameworks your team already knows.
    </Description>
    <Actions>
        <Button Type="ButtonType.Link" To="docs/start" Color="Color.Primary" Size="Size.Large" Padding="Padding.Is4.OnX">
            <Icon Name="IconName.Book" />
            Get Started
        </Button>
        <Button Type="ButtonType.Link" To="blocks" Color="Color.Secondary" Size="Size.Large" Padding="Padding.Is4.OnX">
            <Icon Name="IconName.PlayCircle" />
            View Blocks
        </Button>
    </Actions>
</PageHeader>

<Container Padding="Padding.Is5.OnY">
    <Row>
        @foreach ( var item in HomeStats )
        {
            <Column @key="@item.Label" ColumnSize="ColumnSize.Is12.Is4.OnDesktop" Margin="Margin.Is3.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Paragraph TextSize="TextSize.Heading2" TextWeight="TextWeight.Bold" Margin="Margin.Is0.FromBottom">@item.Value</Paragraph>
                        <Paragraph TextWeight="TextWeight.SemiBold" Margin="Margin.Is1.FromBottom">@item.Label</Paragraph>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">@item.Description</Paragraph>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row>
        <Column Margin="Margin.IsAuto.OnX">
            <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold" TextAlignment="TextAlignment.Center">
                Trusted by teams building serious Blazor products
            </Heading>
            <Lead TextColor="TextColor.Muted" TextAlignment="TextAlignment.Center">
                From internal platforms to customer-facing SaaS, teams use Blazorise to move faster without fragmenting their UI stack.
            </Lead>
        </Column>
    </Row>
    <HomeClientLogos />
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row Flex="Flex.AlignItems.Center">
        <Column ColumnSize="ColumnSize.Is12.Is5.OnDesktop" Margin="Margin.Is4.FromBottom.OnMobile">
            <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                One component model across your preferred CSS framework
            </Heading>
            <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted">
                Standardize application code while still rendering through Bootstrap, Tailwind, Fluent 2, Bulma, Material, and Ant Design providers. The same Blazorise markup can follow different design systems as your product evolves.
            </Paragraph>
            <Div Flex="Flex.Column.Row.OnTablet" Gap="Gap.Is3" Margin="Margin.Is4.FromTop">
                <Button Type="ButtonType.Link" To="docs/usage" Color="Color.Primary">
                    Compare Providers
                </Button>
                <Button Type="ButtonType.Link" To="features" Color="Color.Light">
                    Explore Features
                </Button>
            </Div>
        </Column>
        <Column ColumnSize="ColumnSize.Is12.Is7.OnDesktop">
            <Image Source="img/features/frameworks-1.png" Text="Blazorise CSS framework support" Shadow="Shadow.Small" Border="Border.Rounded" Fluid Loading />
        </Column>
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Div TextAlignment="TextAlignment.Center" Margin="Margin.Is4.FromBottom">
        <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
            Built for product teams, not demo screens
        </Heading>
        <Lead TextColor="TextColor.Muted">
            Blazorise covers the everyday UI layer and the harder application surfaces that usually slow teams down.
        </Lead>
    </Div>

    <Row>
        @foreach ( var item in ProductHighlights )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet.Is3.OnDesktop" Margin="Margin.Is4.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Icon Name="@item.Icon" IconSize="IconSize.x2" TextColor="@item.TextColor" Margin="Margin.Is3.FromBottom" />
                        <Heading Size="HeadingSize.Is4" TextWeight="TextWeight.SemiBold">@item.Title</Heading>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">@item.Description</Paragraph>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row>
        @foreach ( var item in Frameworks )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet.Is4.OnDesktop" Margin="Margin.Is4.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody Flex="Flex.Column" Height="Height.Is100">
                        <Div Flex="Flex.AlignItems.Center" Gap="Gap.Is3" Margin="Margin.Is3.FromBottom">
                            <Image Source="@item.Logo" Text="@item.Title" Width="Width.Px( 32 )" Height="Height.Px( 32 )" />
                            <Heading Size="HeadingSize.Is4" TextWeight="TextWeight.SemiBold" Margin="Margin.Is0">@item.Title</Heading>
                        </Div>
                        <Paragraph TextColor="TextColor.Muted">@item.Description</Paragraph>
                        <Div Flex="Flex.AlignItems.Center.JustifyContent.Between" Gap="Gap.Is3" Margin="Margin.IsAuto.FromTop">
                            <Anchor To="@item.Url" Title="@($"Read the {item.Title} provider guide")">
                                Provider guide
                            </Anchor>
                            <Button Type="ButtonType.Link" To="@item.DemoUrl" Target="Target.Blank" Size="Size.Small" Outline>
                                View demo
                            </Button>
                        </Div>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row Flex="Flex.AlignItems.Center">
        <Column ColumnSize="ColumnSize.Is12.Is6.OnDesktop" Margin="Margin.Is4.FromBottom.OnMobile">
            <Image Source="img/features/code-utils-1.png" Text="Blazorise fluent utilities" Shadow="Shadow.Small" Border="Border.Rounded" Fluid Loading />
        </Column>
        <Column ColumnSize="ColumnSize.Is12.Is6.OnDesktop">
            <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                Ship consistent UI without scattering custom CSS
            </Heading>
            <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted">
                Use Blazorise components and utility parameters for layout, spacing, typography, borders, responsive behavior, and common interaction states directly from Razor.
            </Paragraph>
            <Row Margin="Margin.Is4.FromTop">
                @foreach ( var item in UtilityBenefits )
                {
                    <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet" Margin="Margin.Is3.FromBottom">
                        <Div Flex="Flex.AlignItems.Start" Gap="Gap.Is3">
                            <Icon Name="IconName.Check" TextColor="TextColor.Success" Margin="Margin.Is1.FromTop" />
                            <Div>
                                <Strong>@item.Title</Strong>
                                <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is1.FromTop.Is0.FromBottom">@item.Description</Paragraph>
                            </Div>
                        </Div>
                    </Column>
                }
            </Row>
        </Column>
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Div TextAlignment="TextAlignment.Center" Margin="Margin.Is4.FromBottom">
        <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
            Popular building blocks
        </Heading>
        <Lead TextColor="TextColor.Muted">
            Start with polished components for the screens product teams build most often.
        </Lead>
    </Div>

    <Row>
        @foreach ( var item in PopularComponents )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet.Is4.OnDesktop" Margin="Margin.Is4.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody Flex="Flex.Column" Height="Height.Is100">
                        <Heading Size="HeadingSize.Is4" TextWeight="TextWeight.SemiBold">@item.Title</Heading>
                        <Paragraph TextColor="TextColor.Muted">@item.Description</Paragraph>
                        <Div Margin="Margin.IsAuto.FromTop">
                            <Anchor To="@item.Url" Title="@($"Open {item.Title} documentation")">
                                View documentation
                            </Anchor>
                        </Div>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Row>
        @foreach ( var item in Testimonials )
        {
            <Column @key="@item.Name" ColumnSize="ColumnSize.Is12.Is4.OnDesktop" Margin="Margin.Is4.FromBottom">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Rating SelectedValue="5" ReadOnly />
                        <Blockquote>@item.Quote</Blockquote>
                        <Strong>@item.Name</Strong>
                        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is1.FromTop.Is0.FromBottom">@item.Company</Paragraph>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Card Border="Border.Rounded" Shadow="Shadow.Small">
        <CardBody Padding="Padding.Is5">
            <Row Flex="Flex.AlignItems.Center">
                <Column ColumnSize="ColumnSize.Is12.Is7.OnDesktop">
                    <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
                        Need license coverage, priority support, or implementation help?
                    </Heading>
                    <Paragraph TextSize="TextSize.Large" TextColor="TextColor.Muted" Margin="Margin.Is0.FromBottom">
                        Commercial plans help teams keep UI delivery predictable with direct maintainer support, onboarding, and expert services.
                    </Paragraph>
                </Column>
                <Column ColumnSize="ColumnSize.Is12.Is5.OnDesktop" TextAlignment="TextAlignment.End" Margin="Margin.Is4.FromTop.OnMobile">
                    <Button Type="ButtonType.Link" To="commercial" Color="Color.Primary" Size="Size.Large" Margin="Margin.Is2.FromEnd">
                        Commercial Options
                    </Button>
                    <Button Type="ButtonType.Link" To="pricing" Color="Color.Light" Size="Size.Large">
                        View Pricing
                    </Button>
                </Column>
            </Row>
        </CardBody>
    </Card>
</Container>

<Container Padding="Padding.Is5.OnY">
    <Div TextAlignment="TextAlignment.Center" Margin="Margin.Is4.FromBottom">
        <Heading Size="HeadingSize.Is2" TextWeight="TextWeight.Bold">
            Join the Blazorise community
        </Heading>
        <Lead TextColor="TextColor.Muted">
            Follow product updates, discuss implementation details, report issues, and help shape the roadmap.
        </Lead>
    </Div>

    <Row>
        @foreach ( var item in CommunityLinks )
        {
            <Column @key="@item.Title" ColumnSize="ColumnSize.Is12.Is6.OnTablet.Is3.OnDesktop" Margin="Margin.Is4.FromBottom" TextAlignment="TextAlignment.Center">
                <Card Border="Border.Rounded" Shadow="Shadow.Small" Height="Height.Is100">
                    <CardBody>
                        <Image Source="@item.Icon" Text="@item.Title" Width="Width.Px( 40 )" Height="Height.Px( 40 )" Margin="Margin.Is3.FromBottom" />
                        <Heading Size="HeadingSize.Is4" TextWeight="TextWeight.SemiBold">@item.Title</Heading>
                        <Paragraph TextColor="TextColor.Muted">@item.Description</Paragraph>
                        <Anchor To="@item.Url" Title="@item.LinkTitle" Target="Target.Blank">
                            @item.Action
                        </Anchor>
                    </CardBody>
                </Card>
            </Column>
        }
    </Row>
</Container>

<Container Padding="Padding.Is5.OnY">
    <HomeNewsletterWidget />
</Container>

@code {
    private static readonly HomeStat[] HomeStats =
    [
        new( "100+", "UI components", "Forms, data, navigation, charts, scheduling, media, utilities, and application primitives." ),
        new( "7+", "CSS providers", "Use the framework that matches your product without rewriting component markup." ),
        new( "100k+", "developers", "A mature Blazor ecosystem used by teams building production applications." )
    ];

    private static readonly ProductHighlight[] ProductHighlights =
    [
        new( IconName.LayerGroup, TextColor.Primary, "Complete UI layer", "Reusable components for common screens and advanced product workflows." ),
        new( IconName.Table, TextColor.Info, "Data-heavy apps", "DataGrid, tables, validation, filtering, editing, charts, and scheduling for operational software." ),
        new( IconName.Building, TextColor.Secondary, "Design-system ready", "Theme configuration and provider support make it easier to align Blazorise with your brand." ),
        new( IconName.Headset, TextColor.Success, "Commercial support", "Move critical questions to direct support when delivery timelines matter." )
    ];

    private static readonly FrameworkCard[] Frameworks =
    [
        new( "Fluent 2", "_content/Blazorise.Docs/assets/img/logos/fluent2.svg", "Create modern Microsoft-inspired interfaces with the same Blazorise component model.", "docs/usage/fluent2", "https://demos.blazorise.com/wasm/fluentui2/" ),
        new( "Bootstrap 5", "_content/Blazorise.Docs/assets/img/logos/bootstrap-5.svg", "Use the most familiar responsive frontend toolkit with Blazorise APIs.", "docs/usage/bootstrap5", "https://demos.blazorise.com/wasm/bootstrap5/" ),
        new( "Tailwind", "_content/Blazorise.Docs/assets/img/logos/tailwind.svg", "Pair utility-first styling with productive Blazor components and helpers.", "docs/usage/tailwind", "https://demos.blazorise.com/wasm/tailwind/" ),
        new( "Bulma", "_content/Blazorise.Docs/assets/img/logos/bulma-small.svg", "Build clean Flexbox-based layouts while keeping component behavior consistent.", "docs/usage/bulma", "https://demos.blazorise.com/wasm/bulma/" ),
        new( "Material", "_content/Blazorise.Docs/assets/img/logos/material.svg", "Bring Material Design conventions to Blazor apps without changing your product code shape.", "docs/usage/material", "https://demos.blazorise.com/wasm/material/" ),
        new( "Ant Design", "_content/Blazorise.Docs/assets/img/logos/ant-design.svg", "Use enterprise-style Ant Design visuals through the Blazorise provider abstraction.", "docs/usage/ant-design", "https://demos.blazorise.com/wasm/antdesign/" )
    ];

    private static readonly UtilityBenefit[] UtilityBenefits =
    [
        new( "Expressive Razor", "Keep spacing, flex, border, shadow, and sizing decisions close to the component markup." ),
        new( "Responsive by default", "Compose mobile and desktop behavior through utility parameters instead of isolated CSS patches." ),
        new( "Provider aware", "Let Blazorise render the right classes and structure for the selected CSS framework." ),
        new( "Themeable foundation", "Centralize colors, typography, sizing, and visual rules for product-wide consistency." )
    ];

    private static readonly PopularComponent[] PopularComponents =
    [
        new( "DataGrid", "Sorting, filtering, grouping, virtualization, editing, templates, and validation for complex data screens.", "docs/extensions/datagrid/getting-started" ),
        new( "Scheduler", "Day, week, month, resources, recurrence, and drag-and-drop for calendar-heavy workflows.", "docs/extensions/scheduler" ),
        new( "Charts", "Interactive charts for dashboards, reports, and data visualization in Blazor.", "docs/extensions/chart" ),
        new( "Validation", "Data annotations, custom validators, async checks, localization, and full form workflows.", "docs/components/validation" ),
        new( "Autocomplete", "Fast typeahead, templates, keyboard navigation, and remote data scenarios.", "docs/extensions/autocomplete" ),
        new( "Video", "HLS, DASH, static files, live streams, and protected media support.", "docs/extensions/video" )
    ];

    private static readonly Testimonial[] Testimonials =
    [
        new( "Cristian Recoseanu", "Pebble", "Blazorise helped us build new products quickly while focusing on the features that make them distinctive." ),
        new( "Mark Davis", "Dark Matter Consulting", "Being able to target Bootstrap on desktop and Material for mobile with the same markup is amazing." ),
        new( "ABP Framework", "ABP", "Blazorise is one of the most complete Blazor component libraries and is easy to learn, use, and customize." )
    ];

    private static readonly CommunityLink[] CommunityLinks =
    [
        new( "X", "img/logos/icons8-twitter-x.svg", "Follow release news, product updates, and notes from the Blazorise team.", "Follow us", "https://twitter.com/Blazorise", "Link to Blazorise on X" ),
        new( "Discord", "img/logos/icons8-discord.svg", "Chat with other developers and maintainers when you are working through implementation details.", "Join Discord", "https://discord.gg/cVmq8xBSnG", "Link to Blazorise Discord" ),
        new( "Reddit", "img/logos/icons8-reddit.svg", "Join discussions, release threads, and community conversations around Blazorise.", "Subscribe", "https://www.reddit.com/r/Blazorise/", "Link to Blazorise Reddit" ),
        new( "GitHub", "img/logos/icons8-github.svg", "Open issues, inspect the source, and contribute improvements to the project.", "Contribute", "https://github.com/Megabit/Blazorise", "Link to Blazorise GitHub" )
    ];

    private sealed record HomeStat( string Value, string Label, string Description );

    private sealed record ProductHighlight( IconName Icon, TextColor TextColor, string Title, string Description );

    private sealed record FrameworkCard( string Title, string Logo, string Description, string Url, string DemoUrl );

    private sealed record UtilityBenefit( string Title, string Description );

    private sealed record PopularComponent( string Title, string Description, string Url );

    private sealed record Testimonial( string Name, string Company, string Quote );

    private sealed record CommunityLink( string Title, string Icon, string Description, string Action, string Url, string LinkTitle );
}