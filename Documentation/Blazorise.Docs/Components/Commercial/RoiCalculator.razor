<Paragraph Margin="Margin.Is0.FromBottom.Is4.FromBottom" TextColor="TextColor.Muted">
    Estimate the cost of building internal UI capabilities versus licensing Blazorise over your selected time horizon.
</Paragraph>

<Alert Color="Color.Light" Visible Margin="Margin.Is0.FromBottom.Is4.FromBottom">
    Estimates are directional and depend on project scope, team skill, quality requirements, integration complexity, and maintenance expectations.
</Alert>

<Row Gutter="Gutter.Is4">
    <Column ColumnSize="ColumnSize.Is7.OnDesktop.Is12.OnMobile">
        <Card Border="Border.Rounded" Shadow="Shadow.Small">
            <CardBody>
                <Heading Size="HeadingSize.Is5" Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                    1. Build Effort
                </Heading>

                <RoiAssumptionInput Title="How many UI components do you need?"
                                    Description="Examples: data grid, forms, charts, scheduler."
                                    Value="@ComponentCount"
                                    ValueChanged="@( value => ComponentCount = value )"
                                    Min="@ComponentCountMin"
                                    Max="@ComponentCountMax"
                                    MinText="@ComponentCountMin.ToString( NumberCulture )"
                                    CurrentText="@ComponentCount.ToString( NumberCulture )"
                                    MaxText="@ComponentCountMax.ToString( NumberCulture )" />

                <RoiAssumptionInput Title="Average hours to build one component"
                                    Description="Design, development, testing, documentation, and production hardening."
                                    Value="@HoursPerComponent"
                                    ValueChanged="@( value => HoursPerComponent = value )"
                                    Min="@HoursPerComponentMin"
                                    Max="@HoursPerComponentMax"
                                    Step="4"
                                    MinText="@HoursPerComponentMin.ToString( NumberCulture )"
                                    CurrentText="@HoursPerComponent.ToString( NumberCulture )"
                                    MaxText="@HoursPerComponentMax.ToString( NumberCulture )" />

                <RoiAssumptionInput Title="How many developers will work on this?"
                                    Description="Used to estimate coordination overhead and license seats."
                                    Value="@DeveloperCount"
                                    ValueChanged="@( value => DeveloperCount = value )"
                                    Min="@DeveloperCountMin"
                                    Max="@DeveloperCountMax"
                                    MinText="@DeveloperCountMin.ToString( NumberCulture )"
                                    CurrentText="@DeveloperCount.ToString( NumberCulture )"
                                    MaxText="@DeveloperCountMax.ToString( NumberCulture )" />

                <RoiAssumptionInput Title="Developer cost per hour"
                                    Description="Fully loaded cost including employment, overhead, and delivery coordination."
                                    Value="@DeveloperCostPerHour"
                                    ValueChanged="@( value => DeveloperCostPerHour = value )"
                                    Min="@DeveloperRateMin"
                                    Max="@DeveloperRateMax"
                                    Step="5"
                                    MinText="@FormatCompactCurrency( DeveloperRateMin )"
                                    CurrentText="@FormatCurrency( DeveloperCostPerHour )"
                                    MaxText="@FormatCompactCurrency( DeveloperRateMax )" />

                <Heading Size="HeadingSize.Is5" Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                    2. Delivery &amp; Business Impact
                </Heading>

                <RoiAssumptionInput Title="Months saved by using prebuilt components"
                                    Value="@MonthsSaved"
                                    ValueChanged="@( value => MonthsSaved = value )"
                                    Min="@MonthsSavedMin"
                                    Max="@MonthsSavedMax"
                                    MinText="@MonthsSavedMin.ToString( NumberCulture )"
                                    CurrentText="@MonthsSaved.ToString( NumberCulture )"
                                    MaxText="@MonthsSavedMax.ToString( NumberCulture )" />

                <RoiAssumptionInput Title="Estimated financial impact of launching one month earlier"
                                    Description="Revenue, cost savings, or strategic advantage."
                                    Value="@BusinessValuePerMonth"
                                    ValueChanged="@( value => BusinessValuePerMonth = value )"
                                    Min="@BusinessValuePerMonthMin"
                                    Max="@BusinessValuePerMonthMax"
                                    Step="5000"
                                    MinText="@FormatCompactCurrency( BusinessValuePerMonthMin )"
                                    CurrentText="@FormatCurrency( BusinessValuePerMonth )"
                                    MaxText="@FormatCompactCurrency( BusinessValuePerMonthMax )" />

                <Heading Size="HeadingSize.Is5" Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                    3. Long-Term Ownership &amp; Risk
                </Heading>

                <RoiAssumptionInput Title="Annual maintenance effort (% of build cost)"
                                    Description="Bug fixes, upgrades, improvements, regression testing, and provider compatibility."
                                    Value="@AnnualMaintenancePercent"
                                    ValueChanged="@( value => AnnualMaintenancePercent = value )"
                                    Min="@MaintenancePercentMin"
                                    Max="@MaintenancePercentMax"
                                    MinText="@($"{MaintenancePercentMin:n0}%")"
                                    CurrentText="@($"{AnnualMaintenancePercent:n0}%")"
                                    MaxText="@($"{MaintenancePercentMax:n0}%")" />

                <RoiAssumptionInput Title="Number of years for comparison"
                                    Value="@PlanningYears"
                                    ValueChanged="@( value => PlanningYears = value )"
                                    Min="@PlanningYearsMin"
                                    Max="@PlanningYearsMax"
                                    MinText="@PlanningYearsMin.ToString( NumberCulture )"
                                    CurrentText="@PlanningYears.ToString( NumberCulture )"
                                    MaxText="@PlanningYearsMax.ToString( NumberCulture )" />

                <RoiAssumptionInput Title="Additional effort for testing &amp; hardening (%)"
                                    Value="@TestingHardeningPercent"
                                    ValueChanged="@( value => TestingHardeningPercent = value )"
                                    Min="@HardeningPercentMin"
                                    Max="@HardeningPercentMax"
                                    MinText="@($"{HardeningPercentMin:n0}%")"
                                    CurrentText="@($"{TestingHardeningPercent:n0}%")"
                                    MaxText="@($"{HardeningPercentMax:n0}%")" />

                <RoiAssumptionInput Title="Risk &amp; complexity adjustment (%)"
                                    Description="Unexpected scope, edge cases, production defects, and rework."
                                    Value="@RiskComplexityPercent"
                                    ValueChanged="@( value => RiskComplexityPercent = value )"
                                    Min="@RiskPercentMin"
                                    Max="@RiskPercentMax"
                                    MinText="@($"{RiskPercentMin:n0}%")"
                                    CurrentText="@($"{RiskComplexityPercent:n0}%")"
                                    MaxText="@($"{RiskPercentMax:n0}%")" />

                <Div Margin="Margin.Is0.FromBottom.Is4.FromBottom">
                    <Paragraph Margin="Margin.Is0.FromBottom.Is2.FromBottom" TextWeight="TextWeight.SemiBold">
                        Blazorise license tier used for comparison
                    </Paragraph>
                    <Select TValue="LicenseTier" @bind-Value="@SelectedLicenseTier">
                        <SelectItem TValue="LicenseTier" Value="@LicenseTier.Professional">Professional (@FormatCurrency( ProfessionalLicensePerDeveloperPerYear ) / developer / year)</SelectItem>
                        <SelectItem TValue="LicenseTier" Value="@LicenseTier.Enterprise">Enterprise (@FormatCurrency( EnterpriseLicensePerDeveloperPerYear ) / developer / year)</SelectItem>
                    </Select>
                    <Paragraph Margin="Margin.Is2.FromTop.Is0.FromBottom" TextColor="TextColor.Muted">
                        Selected license price: <Strong>@FormatCurrency( SelectedLicensePrice )</Strong> per developer/year.
                    </Paragraph>
                </Div>
            </CardBody>
        </Card>
    </Column>

    <Column ColumnSize="ColumnSize.Is5.OnDesktop.Is12.OnMobile">
        <Card Border="Border.Rounded" Shadow="Shadow.Small">
            <CardBody>
                @if ( roiResult is null )
                {
                    <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom.Is2.FromBottom">
                        Results
                    </Heading>
                    <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">
                        Adjust assumptions to compare internal build cost with Blazorise.
                    </Paragraph>
                }
                else
                {
                    <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        Results
                    </Heading>

                    <Div Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <Card Border="Border.Rounded" Shadow="Shadow.Small">
                            <CardBody>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">Total Cost to Build Internally</Paragraph>
                                <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom">@FormatCurrency( roiResult.TotalCostToBuildInternally )</Heading>
                            </CardBody>
                        </Card>
                    </Div>

                    <Div Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <Card Border="Border.Rounded" Shadow="Shadow.Small">
                            <CardBody>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">@($"{PlanningYears}-Year Total Cost of Ownership")</Paragraph>
                                <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom">@FormatCurrency( roiResult.TotalCostOfOwnership )</Heading>
                            </CardBody>
                        </Card>
                    </Div>

                    <Div Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <Card Border="Border.Rounded" Shadow="Shadow.Small">
                            <CardBody>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">Total Cost with Blazorise (incl. license)</Paragraph>
                                <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom">@FormatCurrency( roiResult.CostOfUsingBlazorise )</Heading>
                            </CardBody>
                        </Card>
                    </Div>

                    <Div Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <Card Border="Border.Rounded" Shadow="Shadow.Small">
                            <CardBody>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">@($"Blazorise License Cost ({PlanningYears} Years)")</Paragraph>
                                <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom">@FormatCurrency( roiResult.LicenseCostForHorizon )</Heading>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">
                                    @roiResult.EstimatedLicenseSeats seats &times; @FormatCurrency( SelectedLicensePrice ) &times; @PlanningYears years
                                </Paragraph>
                            </CardBody>
                        </Card>
                    </Div>

                    <Div Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <Card Border="Border.Rounded" Shadow="Shadow.Small">
                            <CardBody>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">Cost Difference (In-House &minus; Blazorise)</Paragraph>
                                <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom" TextColor="@(roiResult.EstimatedSavings >= 0m ? TextColor.Success : TextColor.Danger)">
                                    @FormatSignedCurrency( roiResult.EstimatedSavings )
                                </Heading>
                            </CardBody>
                        </Card>
                    </Div>

                    <Div Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <Card Border="Border.Rounded" Shadow="Shadow.Small">
                            <CardBody>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">Time-to-Market Advantage</Paragraph>
                                <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom">@FormatCurrency( roiResult.TimeToMarketAdvantage )</Heading>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">
                                    @MonthsSaved months x @FormatCurrency( BusinessValuePerMonth ) per month
                                </Paragraph>
                            </CardBody>
                        </Card>
                    </Div>

                    <Div Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <Card Border="Border.Rounded" Shadow="Shadow.Small">
                            <CardBody>
                                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Muted">Total Benefit (Savings + Faster Delivery)</Paragraph>
                                <Heading Size="HeadingSize.Is4" Margin="Margin.Is0.FromBottom" TextColor="@(roiResult.TotalBenefit >= 0m ? TextColor.Success : TextColor.Danger)">
                                    @FormatSignedCurrency( roiResult.TotalBenefit )
                                </Heading>
                            </CardBody>
                        </Card>
                    </Div>

                    <Accordion>
                        <AccordionItem @bind-Visible="@costBreakdownVisible">
                            <AccordionHeader>
                                <Heading Size="HeadingSize.Is6" Margin="Margin.Is0">
                                    <AccordionToggle>Cost breakdown</AccordionToggle>
                                </Heading>
                            </AccordionHeader>
                            <AccordionBody TextAlignment="TextAlignment.Start">
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Build effort (in-house)</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@FormatBreakdownHours( roiResult.InternalBuildHours )</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Coordination overhead (in-house)</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@($"{roiResult.InternalCoordinationPercent:n0}%")</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Implementation effort with Blazorise</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@FormatBreakdownHours( roiResult.BlazoriseBuildHours )</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Coordination overhead with Blazorise</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@($"{roiResult.BlazoriseCoordinationPercent:n0}%")</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Annual maintenance (in-house)</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@FormatCurrency( roiResult.InternalAnnualMaintenanceCost )</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Annual maintenance with Blazorise</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@FormatCurrency( roiResult.BlazoriseAnnualMaintenanceCost )</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Developer license seats</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@($"{roiResult.EstimatedLicenseSeats:n0}")</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">@($"License cost ({PlanningYears} years)")</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@FormatCurrency( roiResult.LicenseCostForHorizon )</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Total cost with Blazorise</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@FormatCurrency( roiResult.CostOfUsingBlazorise )</Span>
                                </Paragraph>
                                <Paragraph Border="Border.Is1.OnBottom" Flex="Flex.JustifyContent.Between">
                                    <Span TextSize="TextSize.Small">Planning horizon</Span>
                                    <Span TextWeight="TextWeight.SemiBold">@($"{PlanningYears:n0} years")</Span>
                                </Paragraph>
                            </AccordionBody>
                        </AccordionItem>
                        <AccordionItem @bind-Visible="@calculationNotesVisible">
                            <AccordionHeader>
                                <Heading Size="HeadingSize.Is6" Margin="Margin.Is0">
                                    <AccordionToggle>How this is calculated</AccordionToggle>
                                </Heading>
                            </AccordionHeader>
                            <AccordionBody TextAlignment="TextAlignment.Start">
                                <UnorderedList>
                                    <UnorderedListItem>Internal build cost starts from components x hours per component x developer hourly cost.</UnorderedListItem>
                                    <UnorderedListItem>Internal cost is adjusted for testing, hardening, risk, platform overhead, and coordination overhead.</UnorderedListItem>
                                    <UnorderedListItem>Blazorise still assumes implementation work: @($"{BlazoriseDeliveryEffortPercent:n0}%") of base build effort before reduced hardening, risk, coordination, and maintenance factors.</UnorderedListItem>
                                    <UnorderedListItem>License cost uses annual @SelectedLicenseTier pricing from the commercial pricing constants.</UnorderedListItem>
                                    <UnorderedListItem>Time-to-market advantage is months saved x estimated business value per month.</UnorderedListItem>
                                </UnorderedList>
                            </AccordionBody>
                        </AccordionItem>
                    </Accordion>

                    <Paragraph Margin="Margin.Is3.FromTop.Is0.FromBottom" TextColor="TextColor.Muted">
                        All values represent estimated spend and savings for this scope. Use the emailed summary as a review aid, not as a formal quote.
                    </Paragraph>

                    <Div Margin="Margin.Is4.FromTop.Is0.FromBottom">
                        <Button Color="Color.Primary" Size="Size.Large" Block Clicked="@ShowEmailSummaryModal">
                            Email ROI summary
                        </Button>
                    </Div>
                }
            </CardBody>
        </Card>
    </Column>
</Row>

<Modal @bind-Visible="@emailSummaryModalVisible" Size="ModalSize.Large" Centered>
    <ModalContent>
        <ModalHeader>
            <ModalTitle>Email ROI Summary</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            <Paragraph Margin="Margin.Is0.FromBottom.Is3.FromBottom" TextColor="TextColor.Muted">
                Enter your name and business email and we will send your ROI summary.
            </Paragraph>

            <Validations @ref="@emailSummaryValidationsRef" Mode="ValidationMode.Manual">
                <Validation Validator="ValidationRule.IsNotEmpty">
                    <Field Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <FieldLabel RequiredIndicator>Name</FieldLabel>
                        <FieldBody>
                            <TextInput @bind-Value="@resultRecipientName" Placeholder="Your name">
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </FieldBody>
                    </Field>
                </Validation>

                <Validation Validator="ValidationRule.IsEmail">
                    <Field Margin="Margin.Is0.FromBottom.Is3.FromBottom">
                        <FieldLabel RequiredIndicator>Business Email</FieldLabel>
                        <FieldBody>
                            <TextInput Role="TextRole.Email" @bind-Value="@resultRecipientEmail" Placeholder="name@company.com">
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextInput>
                        </FieldBody>
                    </Field>
                </Validation>

                <Button Color="Color.Primary" Disabled="@isSendingSummaryEmail" Clicked="@SendSummaryEmail">
                    @(isSendingSummaryEmail ? "Sending..." : "Email ROI summary")
                </Button>
            </Validations>

            <Paragraph Margin="Margin.Is3.FromTop.Is0.FromBottom" TextColor="TextColor.Muted">
                By proceeding, you agree to our
                <Anchor To="terms" Title="Link to Terms of Service">Terms of Service</Anchor>
                and
                <Anchor To="privacy" Title="Link to Privacy Policy">Privacy Policy</Anchor>.
            </Paragraph>
        </ModalBody>
    </ModalContent>
</Modal>