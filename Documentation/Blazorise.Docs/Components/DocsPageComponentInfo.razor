<Card Shadow="Shadow.Default" Height="Height.Is100" Width="Width.Is100">
    @if ( !string.IsNullOrWhiteSpace( IllustrationKey ) )
    {
        @if ( ExtensionIllustration )
        {
            <DocsExtensionIllustration For="@IllustrationKey" Name="@Name" />
        }
        else
        {
            <DocsComponentIllustration For="@IllustrationKey" Name="@Name" />
        }
    }
    <CardBody Padding="Padding.Is2.FromBottom" Flex="Flex.Column" Gap="Gap.Is2">
        <CardTitle Size="HeadingSize.Is3">
            <Link To="@To" Stretched Unstyled TextColor="TextColor.Body" TextDecoration="TextDecoration.None">
                @Name
            </Link>
        </CardTitle>
        <Small TextColor="TextColor.Muted">
            @Description
        </Small>
    </CardBody>
</Card>
@code {
    [Parameter] public string Name { get; set; }

    [Parameter] public string Description { get; set; }

    [Parameter] public string To { get; set; }

    [Parameter] public string IllustrationKey { get; set; }

    [Parameter] public bool ExtensionIllustration { get; set; }
}