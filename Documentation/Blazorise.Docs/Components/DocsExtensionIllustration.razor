                <rect x="144" y="86" width="14" height="14" rx="2" /><rect x="170" y="94" width="14" height="14" rx="2" /><rect x="190" y="118" width="14" height="14" rx="2" /><rect x="142" y="126" width="14" height="14" rx="2" />
