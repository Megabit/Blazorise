            <circle cx="88" cy="92" r="12" fill="url(#@AccentFillId)" filter="url(#@ShadowId)" />
            break;
        case "autocomplete":
        case "dropdownlist":
        case "selectlist":
            <rect x="66" y="38" width="188" height="36" rx="8" fill="@Surface" stroke="@Primary" stroke-width="2" filter="url(#@ShadowId)" />
            <rect x="66" y="82" width="188" height="70" rx="8" fill="@Surface" stroke="@Border" stroke-width="2" filter="url(#@ShadowId)" />
            <path d="M92 56h102M222 52l7 8 7-8M92 102h92M92 123h62" stroke="@PrimaryStrong" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
            break;
        case "barcode":
            <rect x="66" y="42" width="188" height="88" rx="9" fill="@Surface" stroke="@Border" stroke-width="2" filter="url(#@ShadowId)" />
            <path d="M92 58v54M106 58v54M126 58v54M136 58v54M154 58v54M182 58v54M194 58v54M218 58v54M230 58v54" stroke="@Overlay" stroke-width="5" />
            <path d="M92 122h138" stroke="@Primary" stroke-width="5" stroke-linecap="round" />
            break;
        case "captcha":
        case "fluent-validation":
            <rect x="72" y="38" width="176" height="92" rx="10" fill="@Surface" stroke="@Border" stroke-width="2" filter="url(#@ShadowId)" />
            <path d="M100 64h94M100 88h74M100 112h104" stroke="@PrimaryStrong" stroke-width="5" stroke-linecap="round" />
            <circle cx="226" cy="64" r="12" fill="@Success" />
            <path d="M220 64l5 5 10-14" stroke="@Surface" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
            break;
        case "chart":
        case "chart-annotation":
        case "chart-datalabels":
        case "chart-live":
        case "chart-trendline":
        case "chart-zoom":
            <rect x="62" y="34" width="196" height="104" rx="10" fill="@Surface" stroke="@Border" stroke-width="2" filter="url(#@ShadowId)" />
