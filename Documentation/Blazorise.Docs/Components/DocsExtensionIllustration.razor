@code {
    [Parameter] public string For { get; set; }

    [Parameter] public string Name { get; set; }

    private string IllustrationKey
    {
        get
        {
            string[] segments = ( For ?? string.Empty ).Split( '/', StringSplitOptions.RemoveEmptyEntries );

            if ( segments.Length < 3 )
                return string.Empty;

            string root = segments[2];

            if ( root == "datagrid" )
            {
                if ( segments.Length == 3 || segments[^1] == "getting-started" )
                    return "datagrid";

                return $"datagrid-{segments[^1]}";
            }

            return root;
        }
    }

    private string AriaLabel => $"{Name} extension illustration";

    private string IdSuffix => IllustrationKey.Replace( "-", "", StringComparison.Ordinal );

    private string FillId => $"docsExtensionIllustrationFill{IdSuffix}";

    private string AccentFillId => $"docsExtensionIllustrationAccent{IdSuffix}";

    private string ShadowId => $"docsExtensionIllustrationShadow{IdSuffix}";

    private string SvgStyle => $"display:block;border-bottom:1px solid {Rule};background:{Canvas}";

    private const string Canvas = "var(--b-theme-light, #fbfcff)";

    private const string Surface = "var(--b-theme-light, #ffffff)";

    private const string SurfaceSubtle = "var(--b-theme-background-light-subtle, #f4f7fb)";

    private const string Border = "var(--b-theme-border-secondary-subtle, #cfd7e6)";

    private const string Rule = "var(--b-theme-border-light-subtle, #e9edf5)";

    private const string Neutral = "var(--b-theme-background-secondary-subtle, #e5e7eb)";

    private const string Overlay = "var(--b-theme-dark, #111827)";

    private const string ShadowColor = "var(--b-theme-dark, #1f2937)";

    private const string Primary = "var(--b-theme-primary, #8b5cf6)";

    private const string PrimaryStrong = "var(--b-theme-primary, #6d28d9)";

    private const string PrimaryDark = "var(--b-theme-primary, #4f46e5)";

    private const string PrimarySoft = "var(--b-theme-background-primary-subtle, #eef2ff)";

    private const string PrimaryMuted = "var(--b-theme-border-primary-subtle, #d8b4fe)";

    private const string InfoSoft = "var(--b-theme-background-info-subtle, #e0f2fe)";

    private const string Success = "var(--b-theme-success, #22c55e)";

    private const string Danger = "var(--b-theme-danger, #ef4444)";

    private const string Warning = "var(--b-theme-warning, #f59e0b)";

    private const string WarningSoft = "var(--b-theme-background-warning-subtle, #fff7ed)";
}