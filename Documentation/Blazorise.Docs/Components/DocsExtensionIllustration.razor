<svg viewBox="0 0 320 150" preserveAspectRatio="xMidYMid slice" width="100%" height="150" role="img" aria-label="@AriaLabel" style="@SvgStyle">
    <defs>
        <linearGradient id="@FillId" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="@Surface" />
            <stop offset="100%" stop-color="@SurfaceSubtle" />
        </linearGradient>
        <linearGradient id="@AccentFillId" x1="0" x2="1" y1="0" y2="1">
            <stop offset="0%" stop-color="@Primary" />
            <stop offset="100%" stop-color="@PrimaryDark" />
        </linearGradient>
        <filter id="@ShadowId" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="5" stdDeviation="6" flood-color="@ShadowColor" flood-opacity=".12" />
        </filter>
    </defs>

    <rect width="320" height="150" fill="url(#@FillId)" />
    <circle cx="280" cy="28" r="38" fill="@PrimarySoft" opacity=".72" />
    <circle cx="54" cy="130" r="46" fill="@InfoSoft" opacity=".45" />

    @switch ( IllustrationKey )
    {
        case "animate":
            <path d="M72 92c28-44 86-54 124-18" fill="none" stroke="@PrimaryMuted" stroke-width="8" stroke-linecap="round" />
            <path d="M94 82c34-34 74-30 104 0" fill="none" stroke="@Primary" stroke-width="8" stroke-linecap="round" />
