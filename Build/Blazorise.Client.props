		<BlazorWebAssemblyLazyLoad Include="Blazorise.PivotGrid.wasm" />
		<BlazorWebAssemblyLazyLoad Include="Blazorise.QRCode.wasm" />
		<BlazorWebAssemblyLazyLoad Include="Blazorise.Scheduler.wasm" />
